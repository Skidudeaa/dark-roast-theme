      "settings": { "foreground": "#8AAC6B" }
    },
    {
      "name": "JSON — number",
      "scope": [
        "constant.numeric.json",
        "meta.structure.dictionary.value.json constant.numeric"
      ],
      "settings": { "foreground": "#D2691E" }
    },
    {
      "name": "JSON — boolean / null",
      "scope": [
        "constant.language.json",
        "meta.structure.dictionary.value.json constant.language"
      ],
      "settings": { "foreground": "#D2691E", "fontStyle": "italic" }
    },

    // ── YAML ──────────────────────────────────────────────────────────────
    {
      "name": "YAML — key",
      "scope": [
        "entity.name.tag.yaml",
        "support.type.property-name.yaml",
        "meta.mapping.key.yaml string"
      ],
      "settings": { "foreground": "#6E8FAD" }
    },
    {
      "name": "YAML — string value",
      "scope": [
        "string.unquoted.yaml",
        "string.quoted.single.yaml",
        "string.quoted.double.yaml"
      ],
      "settings": { "foreground": "#8AAC6B" }
    },
    {
      "name": "YAML — anchor (&name) and alias (*name)",
      "scope": [
        "entity.name.type.anchor.yaml",
        "variable.other.alias.yaml",
        "punctuation.definition.anchor.yaml",
        "punctuation.definition.alias.yaml"
      ],
      "settings": { "foreground": "#E69A4C" }
    },
    {
      "name": "YAML — directive (--- and ...)",
      "scope": [
        "punctuation.definition.directive.yaml",
        "entity.other.document.begin.yaml",
        "entity.other.document.end.yaml"
      ],
      "settings": { "foreground": "#AD7FA8" }
    },

    // ── TOML ──────────────────────────────────────────────────────────────
    {
      "name": "TOML — key",
      "scope": [
        "support.type.property-name.toml",
        "entity.name.tag.toml",
        "variable.key.toml"
      ],
      "settings": { "foreground": "#6E8FAD" }
    },
    {
      "name": "TOML — table header ([section])",
      "scope": [
        "entity.name.section.group-title.toml",
        "variable.other.sectioned-token.toml",
        "support.type.property-name.table.toml"
      ],
      "settings": { "foreground": "#DAA520" }
    },

    // ── Shell / Bash ───────────────────────────────────────────────────────
    {
      "name": "Shell — command name (the verb of the line)",
      "scope": [
        "support.function.builtin.shell",
        "entity.name.command.shell"
      ],
      "settings": { "foreground": "#6E8FAD" }
    },
    {
      "name": "Shell — variable reference ($VAR, ${VAR})",
      "scope": [
        "variable.other.normal.shell",
        "variable.other.bracket.shell",
        "punctuation.definition.variable.shell"
      ],
      "settings": { "foreground": "#4CC4B4" }
    },
    {
      "name": "Shell — flag/option (-v --verbose)",
      "scope": [
        "string.unquoted.argument.shell",
        "meta.argument.shell"
      ],
      "settings": { "foreground": "#E69A4C" }
    },
    {
      "name": "Shell — heredoc delimiter",
      "scope": [
        "keyword.operator.heredoc.shell",
        "entity.name.tag.heredoc.shell"
      ],
      "settings": { "foreground": "#AD7FA8" }
    },
    {
      "name": "Shell — shebang line",
      "scope": [
        "comment.line.shebang"
      ],
      "settings": { "foreground": "#E69A4C", "fontStyle": "italic" }
    },

    // ── Markdown ─────────────────────────────────────────────────────────
    // amber headings: landmarks in a document deserve the primary accent.
    {
      "name": "Markdown — heading (# ## ###)",
      "scope": [
        "markup.heading",
        "entity.name.section.markdown",
        "markup.heading.setext",
        "punctuation.definition.heading.markdown"
      ],
      "settings": { "foreground": "#E69A4C", "fontStyle": "bold" }
    },
    {
      "name": "Markdown — bold text",
      "scope": [
        "markup.bold",
        "markup.bold string"
      ],
      "settings": { "foreground": "#DAA520", "fontStyle": "bold" }
    },
    {
      "name": "Markdown — italic text",
      "scope": [
        "markup.italic",
        "markup.italic string"
      ],
      "settings": { "foreground": "#DAA520", "fontStyle": "italic" }
    },
    {
      "name": "Markdown — bold italic",
      "scope": [
        "markup.bold markup.italic",
        "markup.italic markup.bold"
      ],
      "settings": { "foreground": "#E69A4C", "fontStyle": "bold italic" }
    },
    {
      "name": "Markdown — inline code",
      "scope": [
        "markup.inline.raw",
        "markup.inline.raw.string.markdown"
      ],
      "settings": { "foreground": "#8AAC6B" }
    },
    {
      "name": "Markdown — code block",
      "scope": [
        "markup.raw.block",
        "markup.raw.code-fence",
        "fenced_code.block.language"
      ],
      "settings": { "foreground": "#8AAC6B" }
    },
    {
      "name": "Markdown — link text and URL",
      "scope": [
        "markup.underline.link",
        "markup.underline.link.markdown",
        "markup.underline.link.image.markdown",
        "string.other.link.title.markdown",
        "string.other.link.description.markdown"
      ],
      "settings": { "foreground": "#4CC4B4", "fontStyle": "underline" }
    },
    {
      "name": "Markdown — link brackets [ ] ( )",
      "scope": [
        "punctuation.definition.link.markdown",
        "punctuation.definition.metadata.markdown"
      ],
      "settings": { "foreground": "#4D3B31" }
    },
    {
      "name": "Markdown — image alt text",
      "scope": [
        "string.other.link.description.title.markdown"
      ],
      "settings": { "foreground": "#8B7355" }
    },
    {
      "name": "Markdown — blockquote (> text)",
      "scope": [
        "markup.quote",
        "markup.quote punctuation.definition.blockquote"
      ],
      "settings": { "foreground": "#8B7355", "fontStyle": "italic" }
    },
    {
      "name": "Markdown — list bullet (- * •)",
      "scope": [
        "markup.list",
        "punctuation.definition.list.begin.markdown"
      ],
      "settings": { "foreground": "#8B7355" }
    },
    {
      "name": "Markdown — horizontal rule (---)",
      "scope": [
        "meta.separator.markdown"
      ],
      "settings": { "foreground": "#3C2A21" }
    },
    {
      "name": "Markdown — front matter delimiter (---)",
      "scope": [
        "punctuation.definition.front-matter.yaml",
        "punctuation.definition.front-matter.toml"
      ],
      "settings": { "foreground": "#AD7FA8" }
    },
    {
      "name": "Markdown — strikethrough",
      "scope": [
        "markup.strikethrough"
      ],
      "settings": { "foreground": "#4D3B31", "fontStyle": "strikethrough" }
    },

    // ── Diff / Patch ──────────────────────────────────────────────────────
    // Green=added, Red=removed, Amber=changed — universal diff semantics.
    {
      "name": "Diff — header",
      "scope": [
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": { "foreground": "#8B7355", "fontStyle": "italic" }
    },
    {
      "name": "Diff — inserted line (+ added)",
      "scope": [
        "markup.inserted",
        "markup.inserted.diff",
        "punctuation.definition.inserted"
      ],
      "settings": { "foreground": "#8AAC6B" }
    },
    {
      "name": "Diff — deleted line (- removed)",
      "scope": [
        "markup.deleted",
        "markup.deleted.diff",
        "punctuation.definition.deleted"
      ],
      "settings": { "foreground": "#C44C4C" }
    },
    {
      "name": "Diff — changed line (~ modified)",
      "scope": [
        "markup.changed",
        "markup.changed.diff",
        "punctuation.definition.changed"
      ],
      "settings": { "foreground": "#E69A4C" }
    },
    {
      "name": "Diff — range info (@@ line)",
      "scope": [
        "meta.diff.range",
        "punctuation.definition.range.diff"
      ],
      "settings": { "foreground": "#AD7FA8" }
    },

    // ── Invalid / Error / Deprecated ──────────────────────────────────────
    // scarlet: the only correct use of the highest-weight error color.
    {
      "name": "Invalid / illegal syntax",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": { "foreground": "#C44C4C", "fontStyle": "underline" }
    },
    {
      "name": "Deprecated — visually dying: faded + struck through",
      "scope": [
        "invalid.deprecated"
      ],
      "settings": { "foreground": "#4D3B31", "fontStyle": "strikethrough" }
    },
    {
      "name": "Unimplemented / placeholder (todo!(), unimplemented!())",
      "scope": [
        "support.function.unimplemented"
      ],
      "settings": { "foreground": "#D2691E", "fontStyle": "italic" }
    }
  ]
}
