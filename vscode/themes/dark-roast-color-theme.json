  // ==========================================================================
  // SEMANTIC TOKEN COLORS
  // These run AFTER textmate scopes and override them when VS Code's language
  // server has type-resolved information. Prefer semantic tokens for accuracy.
  // ==========================================================================
  "semanticTokenColors": {
    // ── Variables ──────────────────────────────────────────────────────────
    // crema: default text — variables are the most common token, should be "invisible".
    "variable": "#FFF7EE",
    "variable.readonly": { "foreground": "#FFF7EE", "italic": true },
    // Parameters get italic to signal "input to this scope".
    "parameter": { "foreground": "#FFF7EE", "italic": true },
    "parameter.declaration": { "foreground": "#FFF7EE", "italic": true },

    // ── Properties ─────────────────────────────────────────────────────────
    // bone: slightly receded — object.property reads as "secondary access".
    "property": "#EBE1D7",
    "property.readonly": { "foreground": "#EBE1D7", "italic": true },
    "property.declaration": "#EBE1D7",

    // ── Functions ──────────────────────────────────────────────────────────
    // slate: functions are verbs — cool blue contrasts with warm gold types.
    "function": "#6E8FAD",
    "function.declaration": "#6E8FAD",
    "function.defaultLibrary": { "foreground": "#6E8FAD", "italic": true },
    "method": "#6E8FAD",
    "method.declaration": "#6E8FAD",
    "method.defaultLibrary": { "foreground": "#6E8FAD", "italic": true },
    "member": "#6E8FAD",

    // ── Types / Classes ────────────────────────────────────────────────────
    // gold: warm, authoritative structural nouns. Italic for class names (convention).
    "class": { "foreground": "#DAA520" },
    "class.declaration": { "foreground": "#DAA520" },
    "type": "#DAA520",
    "type.declaration": "#DAA520",
    "interface": "#DAA520",
    "struct": "#DAA520",
    "typeParameter": { "foreground": "#DAA520", "italic": true },

    // ── Enums ─────────────────────────────────────────────────────────────
    // enum container = gold (type-level), enum members = amber-hot (constant values).
    "enum": "#DAA520",
    "enumMember": "#D2691E",
    "enumMember.readonly": { "foreground": "#D2691E", "italic": true },

    // ── Namespaces / modules ───────────────────────────────────────────────
    "namespace": "#EBE1D7",
    "module": "#EBE1D7",

    // ── Decorators ─────────────────────────────────────────────────────────
    // amber: meta-programming deserves attention — the primary accent.
    "decorator": "#E69A4C",
    "annotation": "#E69A4C",

    // ── Keywords ───────────────────────────────────────────────────────────
    // mauve: structural but gentle. You see keywords 500x/day.
    "keyword": "#AD7FA8",
    "modifier": "#AD7FA8",
    "label": "#AD7FA8",

    // ── Operators ─────────────────────────────────────────────────────────
    // teal: connective tissue — eye-catching for = && || without being heavy.
    "operator": "#4CC4B4",
    "operatorOverloaded": { "foreground": "#4CC4B4", "italic": true },

    // ── String literals ────────────────────────────────────────────────────
    "string": "#8AAC6B",

    // ── Numbers & constants ────────────────────────────────────────────────
    "number": "#D2691E",
    "boolean": { "foreground": "#D2691E", "italic": true },

    // ── Comments ───────────────────────────────────────────────────────────
    // mocha italic: must recede completely. Clearly secondary to code.
    "comment": { "foreground": "#8B7355", "italic": true },
    "comment.documentation": { "foreground": "#8B7355", "italic": true },

    // ── Language-specific overrides ────────────────────────────────────────
    // self/this/super: mauve italic — language-special variables get keyword treatment.
    "selfParameter": { "foreground": "#AD7FA8", "italic": true },
    "clsParameter": { "foreground": "#AD7FA8", "italic": true },
    "variable.defaultLibrary": { "foreground": "#D2691E", "italic": true },

    // Macros (Rust): amber — like decorators, meta-level constructs.
    "macro": "#E69A4C",
    "builtinType": { "foreground": "#DAA520", "italic": true },

    // Lifetime parameters (Rust): mocha — structural but tertiary.
    "lifetime": "#8B7355",
    "format_specifier": "#4CC4B4",

    // Unreachable/invalid code: scarlet — errors should be scarlet.
    "unreachableCode": { "foreground": "#C44C4C", "strikethrough": true },
    "deprecated": { "foreground": "#4D3B31", "strikethrough": true }
  },

  // ==========================================================================
  // TOKEN COLORS (TextMate grammar scopes)
  // Applied in order — later rules override earlier ones for the same scope.
  // Canonical syntax mapping defined in the theme spec; see WHY column above.
  // ==========================================================================
  "tokenColors": [

    // ── Comments ────────────────────────────────────────────────────────────
    // mocha italic: must recede. AA-large (4.4:1 on void) — readable but secondary.
    {
      "name": "Comment — line and block",
      "scope": [
        "comment",
        "comment.line",
        "comment.block",
        "punctuation.definition.comment"
      ],
      "settings": { "foreground": "#8B7355", "fontStyle": "italic" }
    },
    {
      "name": "Comment — documentation (JSDoc, Pythondoc, Rustdoc)",
      "scope": [
        "comment.block.documentation",
        "comment.block.javadoc",
        "comment.line.double-slash.documentation"
      ],
      "settings": { "foreground": "#8B7355", "fontStyle": "italic" }
    },
    {
      "name": "Comment — doc tag keywords (@param, @returns, @throws)",
      "scope": [
        "keyword.other.documentation",
        "storage.type.class.jsdoc",
        "punctuation.definition.block.tag.jsdoc",
        "entity.name.type.instance.jsdoc",
        "variable.other.jsdoc"
      ],
      "settings": { "foreground": "#EBE1D7", "fontStyle": "italic" }
    },
    {
      "name": "Comment — TODO / FIXME / NOTE markers",
      "scope": [
        "comment.line keyword",
        "comment.block keyword"
      ],
      "settings": { "foreground": "#E69A4C", "fontStyle": "italic bold" }
    },

    // ── Keywords ────────────────────────────────────────────────────────────
    // mauve: structural but NOT fatiguing. Gentle on eyes over 12-hour shifts.
    {
      "name": "Keyword — control flow (if/else/for/while/return/break/continue)",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.control.flow",
        "keyword.control.loop",
        "keyword.control.conditional",
        "keyword.other",
        "keyword.other.important"
      ],
      "settings": { "foreground": "#AD7FA8" }
    },
    {
      "name": "Keyword — import/from/export/require (italic for module seams)",
      "scope": [
        "keyword.control.import",
        "keyword.control.from",
        "keyword.control.export",
        "keyword.control.default",
        "keyword.control.as"
      ],
      "settings": { "foreground": "#AD7FA8", "fontStyle": "italic" }
    },
    {
      "name": "Keyword — return statement",
      "scope": [
        "keyword.control.return",
        "keyword.control.yield",
