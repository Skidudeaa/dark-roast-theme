{
  // Dark Roast: Black Label — VS Code / Cursor Color Theme
  // Version: 3.0
  //
  // Design system: 16 canonical tokens (void, obsidian, grain, crema, mocha, bone,
  // asparagus, crater, crater-lt, amber, amber-hot, gold, scarlet, teal, sage, slate, mauve)
  //
  // Philosophy: 12-hour-shift optimization. Every color chosen for minimal eye fatigue
  // over extended sessions. Warm-toned backgrounds (void #120C06) keep OLED pixels
  // active at 1.6ms wake, avoiding purple smear of pure black. Cool/warm contrast
  // between functions (slate) and types (gold) makes code scannable without conscious effort.
  //
  // Palette quick reference:
  //   void       #120C06   deepest background (L0: editor)
  //   obsidian   #1E140C   elevated surface (L1: sidebar, terminal, agent panel)
  //   grain      #2A1C13   window frame (L2: title bar, activity bar, status bar, tab strip)
  //   grain-hover#382818   hover / active widgets (L3)
  //   crema      #FFF7EE   primary text
  //   bone       #EBE1D7   reduced-contrast text
  //   mocha      #8B7355   secondary / captions
  //   asparagus  #465945   tertiary metadata
  //   crater     #3C2A21   borders
  //   crater-lt  #4D3B31   strong borders / inactive text
  //   amber      #E69A4C   primary accent / decorators
  //   amber-hot  #D2691E   numbers / constants / regex
  //   gold       #DAA520   types / success
  //   scarlet    #C44C4C   errors / HTML tags / escape chars
  //   teal       #4CC4B4   operators / live data / links
  //   sage       #8AAC6B   strings / diff-added
  //   slate      #6E8FAD   functions / JSON keys / CSS props
  //   mauve      #AD7FA8   keywords / self/this

  "name": "Dark Roast: Black Label",
  "type": "dark",
  "semanticHighlighting": true,

  // ==========================================================================
  // UI CHROME COLORS
  // Every VS Code surface, widget, and decoration.
  // ==========================================================================
  "colors": {

    // ── Global foreground / focus ──────────────────────────────────────────
    // focusBorder: the ring drawn around the focused element (buttons, inputs, etc.)
    "focusBorder": "#4CC4B4",
    "foreground": "#FFF7EE",
    "descriptionForeground": "#8B7355",
    "disabledForeground": "#465945",
    "errorForeground": "#C44C4C",
    "icon.foreground": "#8B7355",
    // selection uses amber at 27% opacity — warm, not visually jarring
    "selection.background": "#E69A4C44",
    "widget.shadow": "#0A060355",
    "widget.border": "#3C2A21",

    // ── Text colors (used in welcome pages, settings, etc.) ───────────────
    "textLink.foreground": "#4CC4B4",
    "textLink.activeForeground": "#6ED8CA",
    "textBlockQuote.background": "#160E08",
    "textBlockQuote.border": "#E69A4C",
    "textCodeBlock.background": "#2A1C13",
    "textPreformat.foreground": "#8AAC6B",
    "textSeparator.foreground": "#3C2A21",

    // ── Editor core ────────────────────────────────────────────────────────
    // Background is void (#120C06) — the deepest OLED-safe warm black.
    "editor.background": "#120C06",
    "editor.foreground": "#FFF7EE",
    // Teal cursor — kinetic, impossible to miss, aligns with "live data" semantics.
    "editorCursor.foreground": "#4CC4B4",
    "editorCursor.background": "#120C06",
    // Current line: grain surface, no border (border would be visually noisy).
    "editor.lineHighlightBackground": "#1E140C",
    "editor.lineHighlightBorder": "#00000000",
    // Line numbers: crater (muted) for inactive, mocha for active.
    "editorLineNumber.foreground": "#3C2A21",
    "editorLineNumber.activeForeground": "#8B7355",
    "editorLineNumber.dimmedForeground": "#2A1C13",

    // ── Selection & highlight ──────────────────────────────────────────────
    // Amber selection family — warm, consistent with the primary accent color.
    "editor.selectionBackground": "#E69A4C33",
    "editor.selectionHighlightBackground": "#E69A4C1A",
    "editor.selectionHighlightBorder": "#E69A4C44",
    "editor.inactiveSelectionBackground": "#E69A4C22",
    // Word highlight uses teal — "live data" — distinct from amber selection.
    "editor.wordHighlightBackground": "#4CC4B41A",
    "editor.wordHighlightBorder": "#4CC4B444",
    "editor.wordHighlightStrongBackground": "#4CC4B433",
    "editor.wordHighlightStrongBorder": "#4CC4B466",

    // ── Find & replace ─────────────────────────────────────────────────────
    "editor.findMatchBackground": "#E69A4C44",
    "editor.findMatchHighlightBackground": "#E69A4C22",
    "editor.findMatchBorder": "#E69A4C",
    "editor.findMatchHighlightBorder": "#E69A4C66",
    "editor.findRangeHighlightBackground": "#4CC4B41A",
    "editor.findRangeHighlightBorder": "#4CC4B44C",
    "editor.rangeHighlightBackground": "#4CC4B41A",
    "editor.rangeHighlightBorder": "#4CC4B44C",

    // ── Gutter ─────────────────────────────────────────────────────────────
    "editorGutter.background": "#120C06",
