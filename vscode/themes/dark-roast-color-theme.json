    "editorBracketPairGuide.background2": "#4CC4B455",
    "editorBracketPairGuide.background3": "#AD7FA855",
    "editorBracketPairGuide.background4": "#DAA52055",
    "editorBracketPairGuide.background5": "#6E8FAD55",
    "editorBracketPairGuide.background6": "#8AAC6B55",
    "editorBracketPairGuide.activeBackground1": "#E69A4CAA",
