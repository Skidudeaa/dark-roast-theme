{
  "themeName": "Dark Roast: Black Label",
  "version": "4.1.0",
  "status": "CANONICAL",
  "_cssMapping": "JSON uses camelCase. CSS uses --dr-kebab-case. Examples: espressoHover → --dr-espresso-hover, amberHot → --dr-amber-hot, darkCacao → --dr-dark-cacao, burntSienna → --dr-burnt-sienna, craterDeep → --dr-crater-deep.",
  "_migration": {
    "from": "3.0.0",
    "breaking": [
      "grain → espresso (value #2A1C13 unchanged)",
      "grainHover → espressoHover (value #382818 unchanged)",
      "crater → craterDeep (value #3C2A21 unchanged)",
      "craterLight/craterLt → crater (value #4D3B31 unchanged, now top of surface scale)",
      "New primitives: darkCacao #1E140E, roastedBean #3C2A1E, burntSienna #C75B39, brass #BFA162",
      "Added semantic role aliases (accent, success, error, warning, critical, stable) pointing at color primitives"
    ]
  },

  "_build": {
    "_note": "Config consumed by scripts/build-tokens.js. Editing this changes generated output.",
    "opacityVariantColors": ["amber", "amberHot", "gold", "scarlet", "teal", "brass", "burntSienna", "magenta", "harvest", "olive"],
    "opacityTiers": { "dim": 0.4, "subtle": 0.1, "ghost": 0.05 },
    "divider": { "color": "crema", "alpha": 0.04 }
  },

  "colors": {
    "_surfaceScale": "Monotonic dark→light: void → obsidian → darkCacao → espresso → roastedBean → crater",
    "void": "#120C06",
    "obsidian": "#160E08",
    "darkCacao": "#1E140E",
    "espresso": "#2A1C13",
    "espressoHover": "#382818",
    "roastedBean": "#3C2A1E",
    "crater": "#4D3B31",
    "craterDeep": "#3C2A21",

    "_foregrounds": "crema = hero/display, bone = reading midpoint, mocha = muted body, warmWhite = bright callouts",
    "crema": "#FFF7EE",
    "warmWhite": "#F0E6D0",
    "bone": "#EBE1D7",
    "mocha": "#8B7355",

    "_geologicalAccents": "asparagus = tertiary metadata, rustic/rose = grounded error states",
    "asparagus": "#465945",
    "rustic": "#480404",
    "rose": "#480607",

    "_actionColors": "Color-name primitives. Semantic roles below alias these.",
    "amber": "#E69A4C",
    "amberHot": "#D2691E",
    "amberMuted": "#C07A4A",
    "gold": "#DAA520",
    "brass": "#BFA162",
    "scarlet": "#C44C4C",
    "burntSienna": "#C75B39",
    "teal": "#4CC4B4",

    "_severityHues": "Clinical severity primitives (Option C, v4.1.0). Distinct hue families so worsening/improving/stable cannot blend at census scanning speed: magenta 333°, harvest 39°, olive 72°. See docs/DESIGN-SYSTEM.md Palette Rules. Directional severity states REQUIRE paired iconography — color is category, icon is direction.",
    "magenta": "#C25F90",
    "harvest": "#D4A040",
    "olive": "#879A39"
  },

  "roles": {
    "_note": "Semantic pointers into colors. Use these in new code for portability; color-name primitives remain canonical.",
    "accent": "amber",
    "accentHot": "amberHot",
    "accentMuted": "amberMuted",
    "success": "teal",
    "warning": "brass",
    "error": "burntSienna",
    "critical": "scarlet",
    "stable": "gold",
    "live": "teal",
    "display": "crema",
    "workhorse": "bone",
    "secondary": "mocha",
    "tertiary": "asparagus"
  },

  "opacity": {
    "_note": "Alpha scale. Hex suffix form: #RRGGBB + hex alpha (e.g., #E69A4C80 = amber at 50%).",
    "0": { "decimal": 0.0, "hex": "00" },
    "4": { "decimal": 0.04, "hex": "0A", "use": "Subtle divider" },
    "5": { "decimal": 0.05, "hex": "0D", "use": "Ghost tier — skeleton loads, faint state" },
    "8": { "decimal": 0.08, "hex": "14", "use": "Hover overlay" },
    "10": { "decimal": 0.10, "hex": "1A", "use": "Subtle tier — hover backgrounds, light fills" },
    "12": { "decimal": 0.12, "hex": "1F" },
    "15": { "decimal": 0.15, "hex": "26" },
    "24": { "decimal": 0.24, "hex": "3D", "use": "Disabled state" },
    "40": { "decimal": 0.40, "hex": "66", "use": "Dim tier — focused borders, scrim under modal" },
    "60": { "decimal": 0.60, "hex": "99", "use": "Heavy scrim" },
    "85": { "decimal": 0.85, "hex": "D9", "use": "Export modal backdrop" },
    "100": { "decimal": 1.0, "hex": "FF" }
  },

  "spacing": {
    "_note": "4px base unit. Numeric keys map to px; aliases map to numeric keys.",
    "unitPx": 4,
    "scale": {
      "0": "0",
      "px": "1px",
      "0.5": "2px",
      "1": "4px",
      "1.5": "6px",
      "2": "8px",
      "3": "12px",
      "4": "16px",
      "5": "20px",
      "6": "24px",
      "8": "32px",
      "10": "40px",
      "12": "48px",
      "16": "64px",
      "20": "80px",
      "24": "96px"
    },
    "aliases": {
      "xs": "1", "sm": "2", "md": "3", "lg": "4", "xl": "6", "2xl": "8", "3xl": "12"
    }
  },

  "radii": {
    "none": "0",
    "xs": "2px",
    "sm": "4px",
    "md": "8px",
    "lg": "12px",
    "xl": "16px",
    "2xl": "24px",
    "full": "9999px"
  },

  "elevation": {
    "_note": "Dark Roast avoids hard drop shadows — uses radial glow + border-weight variation.",
    "flat": {
      "shadow": "none",
      "border": "1px solid rgba(255,255,255,0.04)"
    },
    "raised": {
      "shadow": "0 2px 8px rgba(0,0,0,0.4)",
      "border": "1px solid rgba(255,255,255,0.06)"
    },
    "floating": {
      "shadow": "0 8px 24px rgba(0,0,0,0.5), 0 0 20px rgba(230,154,76,0.12)",
      "border": "1px solid rgba(255,255,255,0.08)",
      "glow": "amber"
    },
    "critical": {
      "shadow": "0 8px 24px rgba(0,0,0,0.6), 0 0 24px rgba(196,76,76,0.20)",
      "border": "1px solid rgba(196,76,76,0.30)",
      "glow": "scarlet"
    },
    "live": {
      "shadow": "0 4px 16px rgba(0,0,0,0.4), 0 0 16px rgba(76,196,180,0.15)",
      "border": "1px solid rgba(76,196,180,0.20)",
      "glow": "teal"
    }
  },

  "glows": {
    "_note": "Multi-layer phosphor box-shadows. Each layer is [blurPx, colorToken|\"#FFFFFF\", alpha]; offset/spread are 0. The white hotspot is the inner bloom, color midband is identification, color wash is atmospheric diffusion. build-tokens.js renders these to box-shadow strings for both CSS (--dr-glow-*) and JS (glow* exports). Layer color tokens resolve against colors above.",
    "amber":          { "layers": [[2, "#FFFFFF", 0.3], [10, "amber", 0.25], [24, "amber", 0.1]] },
    "amberIntense":   { "layers": [[4, "#FFFFFF", 0.5], [14, "amber", 0.4], [32, "amber", 0.15]] },
    "teal":           { "layers": [[2, "#FFFFFF", 0.4], [8, "teal", 0.35], [24, "teal", 0.12]] },
    "tealIntense":    { "layers": [[4, "#FFFFFF", 0.6], [16, "teal", 0.5], [36, "teal", 0.2]] },
    "scarlet":        { "layers": [[2, "#FFFFFF", 0.3], [8, "scarlet", 0.4], [16, "scarlet", 0.15]] },
    "scarletIntense": { "layers": [[4, "#FFFFFF", 0.5], [14, "scarlet", 0.55], [28, "scarlet", 0.2]] },
    "gold":           { "layers": [[2, "#FFFFFF", 0.3], [10, "gold", 0.25], [24, "gold", 0.1]] },
    "goldIntense":    { "layers": [[4, "#FFFFFF", 0.5], [14, "gold", 0.4], [32, "gold", 0.15]] },
    "amberHot":       { "layers": [[2, "#FFFFFF", 0.3], [8, "amberHot", 0.3], [20, "amberHot", 0.1]] },
    "magenta":        { "layers": [[2, "#FFFFFF", 0.3], [8, "magenta", 0.4], [16, "magenta", 0.15]] },
    "harvest":        { "layers": [[2, "#FFFFFF", 0.3], [10, "harvest", 0.25], [24, "harvest", 0.1]] },
    "olive":          { "layers": [[2, "#FFFFFF", 0.3], [10, "olive", 0.25], [24, "olive", 0.1]] },
    "tealGhost":      { "layers": [[4, "teal", 0.08], [12, "teal", 0.03]] }
  },

  "gradients": {
    "_note": "Composed gradients. glass renders as --dr-glass-gradient (CSS, var form), glassGradientCSS (JS, var form), and glassGradient (JS, hex-resolved form).",
    "glass": { "angle": "145deg", "from": "espresso", "to": "craterDeep", "toAlpha": 0.2 }
  },

  "typography": {
    "families": {
      "_fallbackNote": "Fallbacks match the shipped CSS/JS stacks. Modernizing heading/body to system-ui and mono to ui-monospace is a tracked future change (see docs/REORG-PLAN.md), deferred to avoid a silent rendering shift during the restructure.",
      "display": { "family": "Playfair Display", "fallback": "Georgia, serif", "weights": [700, 900], "use": "Hero elements, brand identity, section heroes" },
      "heading": { "family": "Instrument Sans", "fallback": "-apple-system, sans-serif", "weights": [400, 500, 600, 700], "use": "Patient names, track titles, card headers" },
      "body": { "family": "DM Sans", "fallback": "-apple-system, sans-serif", "weights": [400, 500, 700], "use": "Clinical descriptions, UI labels, body copy" },
      "mono": { "family": "Fira Code", "fallback": "'SF Mono', monospace", "weights": [400, 500, 600], "use": "Lab values, ISRC codes, JSON, timestamps, vitals. Ligatures enabled." }
    },
    "scale": {
      "_note": "1.25 minor-third ratio. Line-heights tuned for dense clinical/technical reading.",
      "xs": { "sizePx": 10, "sizeRem": "0.625rem", "lineHeight": 1.4, "letterSpacing": "0.02em", "weight": 500 },
      "sm": { "sizePx": 12, "sizeRem": "0.75rem", "lineHeight": 1.5, "letterSpacing": "0.01em", "weight": 400 },
      "base": { "sizePx": 14, "sizeRem": "0.875rem", "lineHeight": 1.6, "letterSpacing": "0", "weight": 400 },
      "md": { "sizePx": 16, "sizeRem": "1rem", "lineHeight": 1.5, "letterSpacing": "0", "weight": 400 },
      "lg": { "sizePx": 18, "sizeRem": "1.125rem", "lineHeight": 1.4, "letterSpacing": "-0.01em", "weight": 500 },
      "xl": { "sizePx": 22, "sizeRem": "1.375rem", "lineHeight": 1.3, "letterSpacing": "-0.01em", "weight": 600 },
      "2xl": { "sizePx": 28, "sizeRem": "1.75rem", "lineHeight": 1.2, "letterSpacing": "-0.02em", "weight": 700 },
      "3xl": { "sizePx": 36, "sizeRem": "2.25rem", "lineHeight": 1.15, "letterSpacing": "-0.02em", "weight": 700 },
      "4xl": { "sizePx": 48, "sizeRem": "3rem", "lineHeight": 1.1, "letterSpacing": "-0.03em", "weight": 900 },
      "5xl": { "sizePx": 64, "sizeRem": "4rem", "lineHeight": 1.0, "letterSpacing": "-0.03em", "weight": 900 }
    },
    "tracking": {
      "tight": "-0.01em",
      "normal": "0",
      "wide": "0.05em",
      "wider": "0.10em",
      "widest": "0.20em",
      "display": "0.15em"
    },
    "_legacyRem": {
      "_note": "v3 rem-only size tokens retained for backwards compat. JS emits all of these (textXsRem ...); CSS emits only textHuge as --dr-text-huge. Prefer the px-based scale above.",
      "textXsRem": "0.6875rem",
      "textSmRem": "0.8125rem",
      "textBaseRem": "0.9375rem",
      "textLgRem": "1.125rem",
      "textXlRem": "1.5rem",
      "text2xlRem": "2rem",
      "textHuge": "4.5rem"
    },
    "roles": {
      "hero": { "family": "display", "scale": "4xl", "color": "crema" },
      "pageTitle": { "family": "heading", "scale": "2xl", "color": "crema" },
      "section": { "family": "heading", "scale": "xl", "color": "bone" },
      "cardTitle": { "family": "heading", "scale": "lg", "color": "bone" },
      "body": { "family": "body", "scale": "base", "color": "bone" },
      "bodyMuted": { "family": "body", "scale": "base", "color": "mocha" },
      "label": { "family": "body", "scale": "sm", "color": "mocha" },
      "metadata": { "family": "body", "scale": "sm", "color": "asparagus" },
      "code": { "family": "mono", "scale": "base", "color": "bone" },
      "labValue": { "family": "mono", "scale": "md", "color": "bone", "weight": 500 },
      "timestamp": { "family": "mono", "scale": "xs", "color": "asparagus" },
      "vitalSign": { "family": "mono", "scale": "lg", "color": "bone", "weight": 600 }
    }
  },

  "motion": {
    "durations": {
      "instant": "0ms",
      "fast": "120ms",
      "base": "200ms",
      "moderate": "320ms",
      "slow": "480ms",
      "deliberate": "640ms",
      "ambient": "1200ms"
    },
    "_legacyDurations": {
      "_note": "v3 duration names retained as aliases. Prefer v4 names above.",
      "normal": "300ms",
      "theatrical": "500ms",
      "entrance": "600ms"
    },
    "easings": {
      "linear": "linear",
      "default": "cubic-bezier(0.4, 0, 0.2, 1)",
      "easeOut": "cubic-bezier(0.16, 1, 0.3, 1)",
      "easeIn": "cubic-bezier(0.7, 0, 0.84, 0)",
      "easeInOut": "cubic-bezier(0.65, 0, 0.35, 1)",
      "dramatic": "cubic-bezier(0.22, 1, 0.36, 1)",
      "bounce": "cubic-bezier(0.34, 1.56, 0.64, 1)",
      "springSnappy": "cubic-bezier(0.175, 0.885, 0.32, 1.275)",
      "swiftuiSpringSnappy": ".spring(response: 0.35, dampingFraction: 0.7)",
      "swiftuiSpringSoft": ".spring(response: 0.55, dampingFraction: 0.85)"
    },
    "keyframes": {
      "breatheAmber": { "duration": "ambient", "easing": "easeInOut", "use": "Live data indicator, streaming cursor" },
      "pulseScarlet": { "duration": "ambient", "easing": "easeInOut", "use": "Critical severity card, flagged lab" },
      "pulseTeal": { "duration": "2500ms", "easing": "cubic-bezier(0.215, 0.61, 0.355, 1)", "use": "Live data pulsing ring" },
      "shimmerSkeleton": { "duration": "1500ms", "easing": "linear", "use": "Loading skeleton" },
      "grainDrift": { "duration": "8s", "easing": "easeInOut", "use": "Fractal noise overlay drift" },
      "fadeUp": { "duration": "700ms", "easing": "easeOut", "use": "Entrance translation" },
      "slideIn": { "duration": "500ms", "easing": "easeOut", "use": "Entrance from left" },
      "glow": { "duration": "3s", "easing": "easeInOut", "use": "Amber breathing glow" }
    }
  },

  "zIndex": {
    "base": 0,
    "raised": 1,
    "sticky": 100,
    "header": 200,
    "dropdown": 300,
    "overlay": 400,
    "modal": 500,
    "popover": 600,
    "toast": 700,
    "tooltip": 800,
    "debug": 9999
  },

  "icon": {
    "size": {
      "xs": "12px",
      "sm": "14px",
      "md": "16px",
      "lg": "20px",
      "xl": "24px",
      "2xl": "32px",
      "3xl": "48px"
    },
    "strokeWidth": {
      "thin": 1.5,
      "normal": 2,
      "bold": 2.5
    }
  },

  "stripe": {
    "_note": "Geo-sediment stripe at card bottoms (utility: .dr-geo-stripe).",
    "height": "2px",
    "opacity": 0.5
  },

  "stateVariants": {
    "_note": "Applied to any interactive token. Overlays compose with base colors.",
    "hover": { "overlay": "rgba(255,255,255,0.08)", "cursor": "pointer", "transition": "fast" },
    "active": { "overlay": "rgba(0,0,0,0.12)", "transform": "scale(0.98)", "transition": "instant" },
    "focus": { "ring": "0 0 0 3px rgba(230,154,76,0.24)", "outline": "none" },
    "disabled": { "opacity": 0.40, "cursor": "not-allowed", "pointerEvents": "none" },
    "selected": { "background": "rgba(230,154,76,0.15)", "border": "1px solid #E69A4C" }
  },

  "accessibility": {
    "contrastTargets": {
      "_note": "Minimum WCAG contrast ratios per foreground role against void background.",
      "display": { "min": 12.0, "actualVsVoid": 18.31 },
      "workhorse": { "min": 7.0, "actualVsVoid": 15.1 },
      "secondary": { "min": 4.5, "actualVsVoid": 4.33, "note": "Below WCAG AA minimum (4.5) — aspirational target, color uplift needed in future release" },
      "tertiary": { "min": 3.0, "actualVsVoid": 2.57, "note": "Below own minimum (3.0) — aspirational target, color uplift needed in future release" },
      "accent": { "min": 4.5, "actualVsVoid": 8.4 },
      "metadataIgnore": { "min": 1.8, "max": 3.0, "role": "Legible-but-ignorable (Mystic2 IGNORE pattern)" }
    },
    "reducedMotion": {
      "strategy": "All motion durations → instant at runtime. Ambient keyframes (breathe/pulse) become static at 70% opacity."
    },
    "highContrast": {
      "substitutions": {
        "bone": "warmWhite",
        "mocha": "bone",
        "asparagus": "mocha",
        "divider": "rgba(255,255,255,0.12)"
      }
    }
  },

  "printExport": {
    "_note": "Dark Roast does not degrade gracefully to light substrates — explicit inversions required.",
    "substitutions": {
      "void": "#FFFFFF",
      "obsidian": "#FAFAF8",
      "espresso": "#F5F2ED",
      "bone": "#2A1C14",
      "crema": "#120C06",
      "mocha": "#8B7355",
      "amber": "#B26540",
      "burntSienna": "#A23818",
      "teal": "#2A8778"
    },
    "rules": [
      "Never print OLED-optimized tokens directly — substrate inversion required.",
      "Amber accent drops saturation 20% on paper to avoid ink bloom.",
      "Scarlet becomes burgundy on paper — maintains severity meaning."
    ]
  },

  "oledScience": {
    "pureBlackDelayMs": 18.5,
    "voidDelayMs": 1.6,
    "obsidianDelayMs": 1.8,
    "craterDelayMs": 2.1,
    "rationale": "Both void (#120C06) and obsidian (#160E08) keep OLED pixels energized above power-off threshold, eliminating purple-smearing artifacts during high-speed scrolling."
  },

  "appTargets": {
    "somaCURA": {
      "severityMapping": {
        "_note": "Option C (v4.1.0): worsening/improving/stable moved off the amberHot/amber/gold cluster (3° hue spread — collapsed at scanning distance) onto distinct hue families. Color is category only; directional states MUST render paired iconography + sparkline (see iconography table in docs/DESIGN-SYSTEM.md §6).",
        "critical": "scarlet",
        "worsening": "magenta",
        "improving": "harvest",
        "stable": "olive",
        "resolved": "teal"
      },
      "liveIndicator": "teal",
      "pipeline": ["Clinical Update", "HyperDrive NER", "Problem Approval", "SSE Stream → Note"],
      "pipelineStates": {
        "clinicalUpdate": { "color": "mocha", "icon": "pencil.circle", "label": "Input received" },
        "hyperdriveNer": { "color": "amber", "icon": "brain", "label": "NER extracting", "animate": "breatheAmber" },
        "problemApproval": { "color": "brass", "icon": "checklist", "label": "Awaiting approval" },
        "sseStreaming": { "color": "teal", "icon": "wave.3.right", "label": "Streaming note", "animate": "breatheAmber" },
        "noteComplete": { "color": "bone", "icon": "checkmark.seal", "label": "Complete" }
      }
    },
    "songExpanse": {
      "chromeTokens": "AppTheme (void, obsidian, darkCacao, espresso, roastedBean, crater, amber, teal)",
      "contentTokens": "TextColors (song-derived, 9-tier palette from album art)",
      "separation": "Theme provides chrome/UI shell. TextColors provide content areas. Never conflate.",
      "textColorsRules": {
        "_note": "9-tier palette derived from album art. Must meet internal contrast constraints before use.",
        "tiers": {
          "textColor1": { "role": "Primary content FG", "targetContrast": ">= 7.0" },
          "textColor2": { "role": "Secondary content FG", "targetContrast": ">= 4.5" },
          "textColor3": { "role": "Tertiary content FG", "targetContrast": ">= 3.0" },
          "textColor4": { "role": "Accent 1 — lyric highlight", "targetContrast": ">= 4.5" },
          "textColor5": { "role": "Accent 2 — annotation", "targetContrast": ">= 4.5" },
          "textColor6": { "role": "Accent 3 — credits", "targetContrast": ">= 4.5" },
          "textColor7": { "role": "Content surface", "roleType": "bg" },
          "textColor8": { "role": "Elevated content surface", "roleType": "bg" },
          "textColor9": { "role": "Dim content surface", "roleType": "bg" }
        },
        "generationRules": [
          "Extract dominant + accent colors from album art via k-means or perceptual clustering.",
          "Reject palettes where fewer than 3 tiers meet contrast targets against Dark Roast void bg.",
          "If album art fails — fall back to Dark Roast foreground tiers (bone, mocha, asparagus + amber, teal, gold).",
          "Cache generated palette per songId. Invalidate on art change.",
          "Harmonizer step: if clash against current chrome, dim accent tiers by 15%."
        ]
      }
    }
  }
}
