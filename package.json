{
  "name": "dark-roast-theme",
  "version": "5.0.0",
  "description": "Dark Roast: Black Label — OLED-optimized design system. 6-step surface scale, expanded action palette, semantic role aliases, multi-layer phosphor glows, four-tier typography, elevation/motion/z-index/icon scales, and accessibility contrast targets. Generated from a single source of truth (src/tokens.json)",
  "type": "module",
  "main": "index.js",
  "exports": {
    ".": "./index.js",
    "./css": "./dist/css/dark-roast.css",
    "./css/scoped": "./dist/css/dark-roast-scoped.css",
    "./tokens": "./dist/tokens/index.js",
    "./tokens/colors": "./dist/tokens/colors.js",
    "./tokens/typography": "./dist/tokens/typography.js",
    "./tokens/glows": "./dist/tokens/glows.js",
    "./tokens/spacing": "./dist/tokens/spacing.js",
    "./tokens.json": "./src/tokens.json"
  },
  "files": [
    "dist/",
    "src/tokens.json",
    "platforms/",
    "index.js",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "node scripts/build-tokens.js",
    "test": "node scripts/build-tokens.js --check",
    "prepublishOnly": "node scripts/build-tokens.js --check"
  },
  "keywords": [
    "design-system",
    "dark-theme",
    "oled",
    "css-variables",
    "design-tokens",
    "dark-roast",
    "black-label"
  ],
  "author": "skidudeaa",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Skidudeaa/dark-roast-theme.git"
  },
  "homepage": "https://github.com/Skidudeaa/dark-roast-theme#readme",
  "bugs": {
    "url": "https://github.com/Skidudeaa/dark-roast-theme/issues"
  }
}
