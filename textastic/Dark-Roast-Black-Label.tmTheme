<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Dark Roast: Black Label — Textastic / Sublime Text Syntax Theme
  Version: 2.0 (Canonical Overhaul)

  ┌─────────────────────────────────────────────────────────────────────────┐
  │  DESIGN PHILOSOPHY                                                      │
  │                                                                         │
  │  This theme maps the somaNotes Dark Roast design system (dark-roast-    │
  │  tokens.css) to TextMate .tmTheme format. The semantic color grammar    │
  │  is CONSISTENT across all editors (Textastic, Sublime Text, VS Code     │
  │  legacy, TextMate) so that code read on iPad matches code read on       │
  │  desktop — same visual language, same cognitive load.                   │
  │                                                                         │
  │  OLED-SAFETY: void (#120C06) keeps pixels energized at 1.6ms wake      │
  │  delay, avoiding the 18.5ms purple-smearing artifact of pure black.     │
  │  All background alphas are designed for OLED display characteristics.   │
  │                                                                         │
  │  TWELVE-HOUR SHIFT DESIGN: Colors were chosen for low fatigue over      │
  │  long sessions. Mauve for keywords avoids scarlet eye-strain. Sage      │
  │  for strings is warm and organic. Slate for functions is cool contrast  │
  │  without being electric. The warm void background prevents the "white   │
  │  page in a dark room" syndrome of cool-dark themes.                     │
  └─────────────────────────────────────────────────────────────────────────┘

  CANONICAL SYNTAX COLOR MAP (must match all editor themes):
  ┌─────────────────────┬───────────┬──────────┬──────────────────────────────┐
  │ Role                │ Token     │ Hex      │ Why                          │
  ├─────────────────────┼───────────┼──────────┼──────────────────────────────┤
  │ Keywords            │ mauve     │ #AD7FA8  │ Structural but not fatiguing │
  │ Strings             │ sage      │ #8AAC6B  │ Organic data, universal      │
  │ Numbers             │ amber-hot │ #D2691E  │ Warm, stands out quietly     │
  │ Language constants  │ amber-hot │ #D2691E  │ Same family as numbers       │
  │ Functions           │ slate     │ #6E8FAD  │ Cool contrast, scannable     │
  │ Types / Classes     │ gold      │ #DAA520  │ Warm, authoritative nouns    │
  │ Variables           │ crema     │ #FFF7EE  │ Default — stays invisible    │
  │ Parameters          │ crema     │ #FFF7EE  │ Italic signals input scope   │
  │ Properties          │ bone      │ #EBE1D7  │ Slightly receded             │
  │ self/this/super     │ mauve     │ #AD7FA8  │ Language-special = keyword   │
  │ Operators           │ teal      │ #4CC4B4  │ Connective, eye-catching     │
  │ Comments            │ mocha     │ #8B7355  │ Must recede completely       │
  │ Decorators          │ amber     │ #E69A4C  │ Meta-programming = accent    │
  │ HTML tags           │ scarlet   │ #C44C4C  │ Universal red-for-markup     │
  │ HTML attributes     │ amber     │ #E69A4C  │ Constructive parameters      │
  │ CSS properties      │ slate     │ #6E8FAD  │ Properties DO things         │
  │ CSS selectors       │ gold      │ #DAA520  │ Define targets, like types   │
  │ JSON keys           │ slate     │ #6E8FAD  │ Structural keys              │
  │ Regex               │ amber-hot │ #D2691E  │ Patterns, not data           │
  │ Escape sequences    │ scarlet   │ #C44C4C  │ Breaks string flow           │
  │ Invalid / Error     │ scarlet   │ #C44C4C  │ THE correct use for scarlet  │
  │ Deprecated          │ crater-lt │ #4D3B31  │ Visually dying               │
  │ Markdown heading    │ amber     │ #E69A4C  │ Landmarks                    │
  │ Markdown bold       │ gold      │ #DAA520  │ Emphasis                     │
  │ Markdown italic     │ gold      │ #DAA520  │ Light emphasis               │
  │ Markdown code       │ sage      │ #8AAC6B  │ Code = data = strings        │
  │ Markdown link       │ teal      │ #4CC4B4  │ Navigable = kinetic          │
  │ Diff inserted       │ sage      │ #8AAC6B  │ Green = added                │
  │ Diff deleted        │ scarlet   │ #C44C4C  │ Red = removed                │
  │ Diff changed        │ amber     │ #E69A4C  │ Amber = modified             │
  └─────────────────────┴───────────┴──────────┴──────────────────────────────┘

  FULL COLOR PALETTE (from dark-roast-tokens.css v4.0.0; hex unchanged from v3):
    void         #120C06   Deepest background (OLED-safe)
    obsidian     #160E08   Elevated surface
    dark-cacao   #1E140E   Modals / sheets (new in v4)
    espresso     #2A1C13   Card / panel surface (v4: was `grain`)
    espresso-hov #382818   Hover lift (v4: was `grain-hover`)
    roasted-bean #3C2A1E   Borders / dividers (new in v4)
    crema        #FFF7EE   Primary text (17:1 contrast on void)
    warm-white   #F0E6D0   Bright callouts, ANSI 15 (new in v4)
    mocha        #8B7355   Secondary text
    bone         #EBE1D7   Reduced-contrast text
    asparagus    #465945   Tertiary metadata
    crater-deep  #3C2A21   Borders (v4: was `crater`)
    crater       #4D3B31   Strong borders (v4: was `crater-lt`)
    rustic       #480404   Atmospheric red
    rose         #480607   Error bg tint
    amber        #E69A4C   Primary accent
    amber-hot    #D2691E   Gradient terminal
    amber-muted  #C07A4A   Reader contexts (new in v4)
    gold         #DAA520   Stable severity
    brass        #BFA162   Warning (new in v4)
    scarlet      #C44C4C   Clinical critical
    burnt-sienna #C75B39   Terminal red (new in v4)
    teal         #4CC4B4   Live data / success
    sage         #8AAC6B   Warm green (terminal ext)
    slate        #6E8FAD   Dusty blue (terminal ext)
    mauve        #AD7FA8   Dried lavender (terminal ext)

  NOTE: Inline token-role comments elsewhere in this file still use v3 names
  (crater-lt, grain) as role descriptors — they're purely cosmetic. Hex
  values are the authoritative source of truth.

  INSTALL (iOS / iPadOS Textastic):
    1. Place this file in Textastic → Local Files → #Textastic/
    2. Settings → Other → Reload Customizations (or Cmd-Shift-R)
    3. Settings → Code Editor → Theme → "Dark Roast: Black Label"

  INSTALL (macOS Textastic):
    1. Copy to ~/Library/Containers/com.textasticapp.textastic-mac/
       Data/Library/Application Support/Textastic/
    2. Restart Textastic

  INSTALL (Sublime Text):
    1. Copy to Packages/User/
    2. Preferences → Color Scheme → User → Dark Roast: Black Label
-->
<plist version="1.0">
<dict>
  <key>name</key>
  <string>Dark Roast: Black Label</string>

  <key>uuid</key>
  <string>23707EF3-1F96-43C3-946F-4DFFA64AF02C</string>

  <key>semanticClass</key>
  <string>theme.dark.dark-roast</string>

  <key>author</key>
  <string>somaNotes / somaExpanse</string>

  <key>settings</key>
  <array>

    <!-- ════════════════════════════════════════════════════════════════════
         §1  GLOBAL EDITOR CHROME
         ════════════════════════════════════════════════════════════════════
         These settings have no <scope> — they apply to the entire editor.
         Every value maps to a named DR token. The warm void background
         (#120C06) is the defining feature of the Dark Roast aesthetic:
         near-black with brown undertones instead of purple or blue.
         ════════════════════════════════════════════════════════════════════ -->
    <dict>
      <key>settings</key>
      <dict>

        <!-- BACKGROUNDS ─────────────────────────────────────────────────── -->
        <key>background</key>
        <string>#120C06</string>
        <!-- DR void — OLED-safe warm near-black. Avoids purple smear of #000. -->

        <!-- FOREGROUNDS ─────────────────────────────────────────────────── -->
        <key>foreground</key>
        <string>#FFF7EE</string>
        <!-- DR crema — 17.08:1 contrast ratio against void. Warm ivory. -->

        <!-- CARET ───────────────────────────────────────────────────────── -->
        <key>caret</key>
        <string>#4CC4B4</string>
        <!-- DR teal — kinetic, easy to track. Changed from amber to teal
             per canonical spec: caret = teal (live cursor = live data). -->

        <!-- CURRENT LINE HIGHLIGHT ──────────────────────────────────────── -->
        <key>lineHighlight</key>
        <string>#160E0880</string>
        <!-- DR obsidian @ 50% alpha — barely perceptible lift from void.
             Gentle enough to not distract during reading, visible enough
             to anchor the active line during editing. -->

        <!-- SELECTION ───────────────────────────────────────────────────── -->
        <key>selection</key>
        <string>#2A1C13CC</string>
        <!-- DR grain @ 80% alpha — warm selection well above void floor. -->

        <key>selectionForeground</key>
        <string>#FFF7EE</string>
        <!-- DR crema — keep text fully legible within selection. -->

        <key>selectionBorder</key>
        <string>#4D3B3166</string>
        <!-- DR crater-lt @ 40% — subtle warm edge on selection block. -->

        <key>inactiveSelection</key>
        <string>#2A1C1366</string>
        <!-- DR grain @ 40% — faded when window loses focus. -->

        <!-- INVISIBLES (whitespace / tab markers) ───────────────────────── -->
        <key>invisibles</key>
        <string>#3C2A2180</string>
        <!-- DR crater @ 50% — present when "show invisibles" is on,
             recedes completely when off. -->

        <!-- FIND / SEARCH HIGHLIGHTS ────────────────────────────────────── -->
        <key>findHighlight</key>
        <string>#E69A4C</string>
        <!-- DR amber — matches pop against void without screaming. -->

        <key>findHighlightForeground</key>
        <string>#120C06</string>
        <!-- DR void — inverted for maximum contrast on amber highlight. -->

        <!-- BRACKET MATCHING ────────────────────────────────────────────── -->
        <key>bracketsForeground</key>
        <string>#4CC4B4</string>
        <!-- DR teal — kinetic pairing: brackets light up when matched. -->

        <key>bracketsOptions</key>
        <string>underline</string>

        <key>bracketsContentsForeground</key>
        <string>#4CC4B480</string>
        <!-- DR teal @ 50% — contents of matched bracket subtly highlighted. -->

        <key>bracketsContentsOptions</key>
        <string>underline</string>

        <!-- GUTTER (LINE NUMBERS) ───────────────────────────────────────── -->
        <key>gutter</key>
        <string>#120C06</string>
        <!-- DR void — gutter flush with editor bg for seamless appearance. -->

        <key>gutterForeground</key>
        <string>#8B735580</string>
        <!-- DR mocha @ 50% — line numbers recede from code entirely. -->

        <!-- INDENT GUIDES ───────────────────────────────────────────────── -->
        <key>guide</key>
        <string>#3C2A2140</string>
        <!-- DR crater @ 25% — barely visible passive indent guides. -->

        <key>activeGuide</key>
        <string>#4D3B31CC</string>
        <!-- DR crater-lt @ 80% — active guide for current nesting scope. -->

        <key>stackGuide</key>
        <string>#3C2A2130</string>
        <!-- DR crater @ 19% — grandparent scope guides, ultra-faint. -->

        <!-- RULERS / COLUMN GUIDES ──────────────────────────────────────── -->
        <key>rulers</key>
        <string>#3C2A2160</string>
        <!-- DR crater @ 38% — column ruler visible but not distracting. -->

        <!-- MISSPELLING INDICATOR ───────────────────────────────────────── -->
        <key>misspelling</key>
        <string>#C44C4C</string>
        <!-- DR scarlet — same color as invalid code; error is error. -->

        <!-- SHADOW (Sublime Text minimap + scroll shadow) ───────────────── -->
        <key>shadow</key>
        <string>#120C0640</string>
        <!-- DR void @ 25% — subtle panel separator shadow. -->

        <key>shadowWidth</key>
        <string>4</string>

      </dict>
    </dict>


    <!-- ════════════════════════════════════════════════════════════════════
         §2  COMMENTS
         ════════════════════════════════════════════════════════════════════
         Comments are context, not executable code. They MUST recede from
         the visual hierarchy. Mocha (#8B7355) is warm enough to stay
         readable under gaze but dim enough to never compete with code.
         Italic is the universal typographic signal for "annotation".
         ════════════════════════════════════════════════════════════════════ -->

    <dict>
      <key>name</key>    <string>Comment — Inline / Block</string>
      <key>scope</key>   <string>comment, comment.line, comment.block</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#8B7355</string>  <!-- DR mocha -->
        <key>fontStyle</key>   <string>italic</string>
      </dict>
    </dict>

    <!-- Documentation comments (JSDoc, PyDoc, RustDoc, Swift ///):
         Same mocha/italic treatment — they ARE comments, just structured ones.
         Individual doc-tags (e.g. @param, @returns) get amber below. -->
    <dict>
      <key>name</key>    <string>Comment — Documentation</string>
      <key>scope</key>   <string>comment.block.documentation, comment.line.documentation</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#8B7355</string>  <!-- DR mocha -->
        <key>fontStyle</key>   <string>italic</string>
      </dict>
    </dict>

    <!-- Doc-comment tags: @param, @returns, @throws, @see, @deprecated -->
    <dict>
      <key>name</key>    <string>Comment — Doc Tag</string>
      <key>scope</key>   <string>keyword.other.documentation, storage.type.annotation.java,
        punctuation.definition.comment.doc-tag, entity.name.tag.documentation</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#E69A4C</string>  <!-- DR amber — tags stand out within comments -->
        <key>fontStyle</key>   <string>italic</string>
      </dict>
    </dict>

    <!-- TODO / FIXME / HACK / NOTE markers within comments -->
    <dict>
      <key>name</key>    <string>Comment — TODO / FIXME Marker</string>
      <key>scope</key>   <string>comment keyword.codetag.notation,
        comment.line keyword.todo, comment.line keyword.fixme,
        comment.block keyword.todo, comment.block keyword.fixme</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#D2691E</string>  <!-- DR amber-hot — demands attention inside a comment -->
        <key>fontStyle</key>   <string>bold italic</string>
      </dict>
    </dict>

    <!-- Shebang lines (#! /usr/bin/env python3) -->
    <dict>
      <key>name</key>    <string>Comment — Shebang</string>
      <key>scope</key>   <string>comment.line.shebang</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#4D3B31</string>  <!-- DR crater-lt — almost invisible -->
        <key>fontStyle</key>   <string>italic</string>
      </dict>
    </dict>


    <!-- ════════════════════════════════════════════════════════════════════
         §3  STRINGS
         ════════════════════════════════════════════════════════════════════
         Strings are inert data — they hold values but don't execute.
         Sage (#8AAC6B) is warm green, the universal "data/string" signal.
         The sage family groups: raw strings, byte strings, template strings,
         heredocs, and multiline strings all in the same visual bucket.
         ════════════════════════════════════════════════════════════════════ -->

    <dict>
      <key>name</key>    <string>String — All Variants</string>
      <key>scope</key>   <string>string,
        string.quoted.single, string.quoted.double,
        string.quoted.triple, string.quoted.other,
        string.unquoted, string.other</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#8AAC6B</string>  <!-- DR sage -->
      </dict>
    </dict>

    <!-- String punctuation (opening/closing quotes): slightly dimmer sage -->
    <dict>
      <key>name</key>    <string>String — Punctuation (Quotes)</string>
      <key>scope</key>   <string>punctuation.definition.string.begin,
        punctuation.definition.string.end</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#8AAC6B</string>  <!-- DR sage — unified with string body -->
      </dict>
    </dict>

    <!-- Template string / interpolated string containers -->
    <dict>
      <key>name</key>    <string>String — Template / Interpolated</string>
      <key>scope</key>   <string>string.template, string.interpolated</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#8AAC6B</string>  <!-- DR sage -->
      </dict>
    </dict>

    <!-- Template expression delimiters: ${...} `${` / `}` / #{} / \(...) -->
    <dict>
      <key>name</key>    <string>String — Template Expression Punctuation</string>
      <key>scope</key>   <string>punctuation.definition.template-expression.begin,
        punctuation.definition.template-expression.end,
        punctuation.section.embedded.begin, punctuation.section.embedded.end,
        punctuation.definition.interpolation.begin,
        punctuation.definition.interpolation.end</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#4CC4B4</string>  <!-- DR teal — evaluated = live -->
      </dict>
    </dict>

    <!-- Escape sequences (\n \t \u0041 \' \") — scarlet: breaks string flow -->
    <dict>
      <key>name</key>    <string>String — Escape Sequence</string>
      <key>scope</key>   <string>constant.character.escape,
        constant.character.escape.unicode,
        constant.character.escape.hex,
        constant.character.escape.octal</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#C44C4C</string>  <!-- DR scarlet — demands attention -->
        <key>fontStyle</key>   <string>bold</string>
      </dict>
    </dict>

    <!-- Regular expressions -->
    <dict>
      <key>name</key>    <string>String — Regular Expression</string>
      <key>scope</key>   <string>string.regexp,
        string.regexp.python, string.regexp.ruby,
        source.regexp, source.js.regexp</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#D2691E</string>  <!-- DR amber-hot italic — patterns, not data -->
        <key>fontStyle</key>   <string>italic</string>
      </dict>
    </dict>

    <!-- Regex special characters (. * + ? | ^ $ [ ] { } \) -->
    <dict>
      <key>name</key>    <string>String — Regex Special Chars</string>
      <key>scope</key>   <string>keyword.operator.quantifier.regexp,
        keyword.operator.or.regexp, keyword.operator.negation.regexp,
        punctuation.definition.character-class.regexp</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#E69A4C</string>  <!-- DR amber — sub-structure within pattern -->
      </dict>
    </dict>

    <!-- Heredoc / raw string / byte string labels (Python b"", r"", Swift #""#) -->
    <dict>
      <key>name</key>    <string>String — Raw / Byte Prefix</string>
      <key>scope</key>   <string>storage.type.string.python,
        punctuation.definition.string.raw.begin,
        punctuation.definition.string.raw.end</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#D2691E</string>  <!-- DR amber-hot — modifier signals "not plain string" -->
        <key>fontStyle</key>   <string>italic</string>
      </dict>
    </dict>


    <!-- ════════════════════════════════════════════════════════════════════
         §4  NUMBERS & LANGUAGE CONSTANTS
         ════════════════════════════════════════════════════════════════════
         Numbers are literal values — amber-hot (#D2691E) makes them
         stand out from surrounding crema text without screaming.
         Language constants (true/false/null/nil/None) belong in the
         same visual family as numbers: they ARE constant values.
         ════════════════════════════════════════════════════════════════════ -->

    <dict>
      <key>name</key>    <string>Number — All Numeric Literals</string>
      <key>scope</key>   <string>constant.numeric,
        constant.numeric.integer, constant.numeric.float,
        constant.numeric.hex, constant.numeric.octal,
        constant.numeric.binary, constant.numeric.complex</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#D2691E</string>  <!-- DR amber-hot -->
      </dict>
    </dict>

    <!-- Language constants: true, false, null, nil, None, undefined, NaN, Infinity -->
    <dict>
      <key>name</key>    <string>Constant — Language (true/false/null/nil)</string>
      <key>scope</key>   <string>constant.language,
        constant.language.boolean, constant.language.null,
        constant.language.undefined, constant.language.nan</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#D2691E</string>  <!-- DR amber-hot italic -->
        <key>fontStyle</key>   <string>italic</string>
      </dict>
    </dict>

    <!-- Symbolic constants (enum variants, compile-time constants, Ruby symbols) -->
    <dict>
      <key>name</key>    <string>Constant — Other (enum variants, symbols)</string>
      <key>scope</key>   <string>constant.other,
        constant.other.symbol, constant.other.enum,
        constant.other.ruby</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#D2691E</string>  <!-- DR amber-hot -->
      </dict>
    </dict>

    <!-- Built-in/library constants (Math.PI, std::INT_MAX, UIColor.red) -->
    <dict>
      <key>name</key>    <string>Constant — Built-in / Support</string>
      <key>scope</key>   <string>support.constant,
        support.constant.math, support.constant.dom,
        support.constant.color, support.constant.font-name,
        support.constant.property-value</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#DAA520</string>  <!-- DR gold — library-provided, stable -->
      </dict>
    </dict>


    <!-- ════════════════════════════════════════════════════════════════════
         §5  KEYWORDS
         ════════════════════════════════════════════════════════════════════
         Keywords are structural control words — they define program flow.
         Mauve (#AD7FA8) is the canonical keyword color: lavender-purple
         that is structurally distinct without the fatigue of scarlet.
         12-hour shift design: scarlet is reserved for ACTUAL errors.
         ════════════════════════════════════════════════════════════════════ -->

    <!-- Base keyword catch-all (import, export, return, yield, async, await,
         pass, break, continue, throw, raise, delete, typeof, instanceof,
         new, void, in, of, as, from, where, select, …) -->
    <dict>
      <key>name</key>    <string>Keyword — General</string>
      <key>scope</key>   <string>keyword, keyword.other</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#AD7FA8</string>  <!-- DR mauve -->
      </dict>
    </dict>

    <!-- Control flow: if, else, elif, for, while, do, switch, case,
         default, guard, try, catch, finally, with, match, when -->
    <dict>
      <key>name</key>    <string>Keyword — Control Flow</string>
      <key>scope</key>   <string>keyword.control,
        keyword.control.flow, keyword.control.conditional,
        keyword.control.loop, keyword.control.exception,
        keyword.control.import, keyword.control.return</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#AD7FA8</string>  <!-- DR mauve bold -->
        <key>fontStyle</key>   <string>bold</string>
      </dict>
    </dict>

    <!-- Operators: = == === != !== < > <= >= + - * / % ** & | ^ ~ << >>
         && || ! ? : ?. ?? ... -> => -->
    <dict>
      <key>name</key>    <string>Keyword — Operator</string>
      <key>scope</key>   <string>keyword.operator,
        keyword.operator.arithmetic, keyword.operator.assignment,
        keyword.operator.comparison, keyword.operator.logical,
        keyword.operator.bitwise, keyword.operator.ternary,
        keyword.operator.spread, keyword.operator.rest,
        keyword.operator.range, keyword.operator.optional-chaining,
        keyword.operator.nullish, keyword.operator.relational,
        keyword.operator.type, keyword.operator.cast</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#4CC4B4</string>  <!-- DR teal — connective tissue, eye-catching -->
      </dict>
    </dict>

    <!-- Namespace/resolution operators (::, ., ->, .?) — quieter variant -->
    <dict>
      <key>name</key>    <string>Keyword — Accessor / Resolution Operator</string>
      <key>scope</key>   <string>keyword.operator.accessor,
        keyword.operator.namespace, keyword.operator.member,
        punctuation.accessor, meta.path punctuation</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#4D3B31</string>  <!-- DR crater-lt — structural but quiet -->
      </dict>
    </dict>

    <!-- Word-form operators: and, or, not, is, in, as, instanceof, typeof -->
    <dict>
      <key>name</key>    <string>Keyword — Word Operator</string>
      <key>scope</key>   <string>keyword.operator.word,
        keyword.operator.logical.python,
        keyword.operator.comparison.python</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#4CC4B4</string>  <!-- DR teal — same as symbol operators -->
        <key>fontStyle</key>   <string>italic</string>
      </dict>
    </dict>


    <!-- ════════════════════════════════════════════════════════════════════
         §6  STORAGE (type declarations, modifiers)
         ════════════════════════════════════════════════════════════════════
         Storage types (var, let, const, func, def, fn, class, struct,
         enum, interface, type, pub, private, static, async, mut, …) are
         declaration-level keywords. They belong in the mauve family with
         keywords, italic to signal "modifier/declarator" semantics.
         ════════════════════════════════════════════════════════════════════ -->

    <!-- Type declaration keywords: class, struct, enum, interface, protocol,
         trait, type (Swift/TS typedef), union, impl, extension, namespace -->
    <dict>
      <key>name</key>    <string>Storage — Type Declaration</string>
      <key>scope</key>   <string>storage.type,
        storage.type.class, storage.type.struct, storage.type.enum,
        storage.type.interface, storage.type.function,
        storage.type.annotation, storage.type.generic,
        storage.type.primitive, storage.type.namespace</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#AD7FA8</string>  <!-- DR mauve italic -->
        <key>fontStyle</key>   <string>italic</string>
      </dict>
    </dict>

    <!-- Access/visibility modifiers: public, private, protected, internal,
         static, final, abstract, override, readonly, const, mut, unsafe,
         async, virtual, extern, inline, export, default -->
    <dict>
      <key>name</key>    <string>Storage — Modifier</string>
      <key>scope</key>   <string>storage.modifier,
        storage.modifier.access, storage.modifier.async,
        storage.modifier.static, storage.modifier.abstract,
        storage.modifier.final, storage.modifier.const,
        storage.modifier.export, storage.modifier.import</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#AD7FA8</string>  <!-- DR mauve italic -->
        <key>fontStyle</key>   <string>italic</string>
      </dict>
    </dict>


    <!-- ════════════════════════════════════════════════════════════════════
         §7  FUNCTIONS
         ════════════════════════════════════════════════════════════════════
         Functions are the VERBS of code — they DO things. Slate (#6E8FAD)
         is a cool dusty blue that creates natural contrast against the warm
         amber/gold type and sage string colors. Functions are immediately
         scannable against the warm backdrop.
         ════════════════════════════════════════════════════════════════════ -->

    <!-- Function / method declarations (the name being defined) -->
    <dict>
      <key>name</key>    <string>Function — Declaration Name</string>
      <key>scope</key>   <string>entity.name.function,
        entity.name.function.python, entity.name.function.ruby,
        entity.name.function.php, entity.name.method,
        entity.name.function.member</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#6E8FAD</string>  <!-- DR slate -->
      </dict>
    </dict>

    <!-- Function calls / invocations -->
    <dict>
      <key>name</key>    <string>Function — Call / Invocation</string>
      <key>scope</key>   <string>meta.function-call,
        meta.function-call.generic, variable.function,
        support.function.call, meta.method-call</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#6E8FAD</string>  <!-- DR slate -->
      </dict>
    </dict>

    <!-- Built-in / standard library functions -->
    <dict>
      <key>name</key>    <string>Function — Built-in / Support</string>
      <key>scope</key>   <string>support.function,
        support.function.builtin, support.function.console,
        support.function.string, support.function.array,
        support.function.math, support.function.misc,
        support.function.kernel, support.function.print</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#6E8FAD</string>  <!-- DR slate italic — builtin = provided by runtime -->
        <key>fontStyle</key>   <string>italic</string>
      </dict>
    </dict>

    <!-- Constructor calls: new Foo(), Class(), __init__ -->
    <dict>
      <key>name</key>    <string>Function — Constructor</string>
      <key>scope</key>   <string>entity.name.function.constructor,
        meta.instance.constructor, keyword.operator.new</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#6E8FAD</string>  <!-- DR slate bold — construction = important call -->
        <key>fontStyle</key>   <string>bold</string>
      </dict>
    </dict>

    <!-- Anonymous / arrow functions (visual body — the => token) -->
    <dict>
      <key>name</key>    <string>Function — Arrow / Lambda</string>
      <key>scope</key>   <string>storage.type.arrow, keyword.declaration.arrow,
        punctuation.definition.arrow, keyword.operator.arrow</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#4CC4B4</string>  <!-- DR teal — arrow is an operator -->
      </dict>
    </dict>


    <!-- ════════════════════════════════════════════════════════════════════
         §8  TYPES, CLASSES, STRUCTS
         ════════════════════════════════════════════════════════════════════
         Types are structural NOUNS — they describe shape and capability.
         Gold (#DAA520) is warm and authoritative. It maps to the "stable"
         state in the clinical severity gradient: types don't change at
         runtime, they ground everything else.
         ════════════════════════════════════════════════════════════════════ -->

    <!-- Named types: class names, struct names, enum names being defined -->
    <dict>
      <key>name</key>    <string>Type — Class / Struct / Enum Name (Definition)</string>
      <key>scope</key>   <string>entity.name.class, entity.name.struct,
        entity.name.enum, entity.name.type, entity.name.interface,
        entity.name.trait, entity.name.union, entity.name.protocol</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#DAA520</string>  <!-- DR gold bold -->
        <key>fontStyle</key>   <string>bold</string>
      </dict>
    </dict>

    <!-- Inherited class / protocol conformance -->
    <dict>
      <key>name</key>    <string>Type — Inherited Class / Conforms To</string>
      <key>scope</key>   <string>entity.other.inherited-class</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#DAA520</string>  <!-- DR gold italic — subordinate to definition -->
        <key>fontStyle</key>   <string>italic</string>
      </dict>
    </dict>

    <!-- Type references (used as annotations, casts, generic params) -->
    <dict>
      <key>name</key>    <string>Type — Reference / Support Type</string>
      <key>scope</key>   <string>support.type, support.class,
        support.type.primitive, support.type.builtin,
        support.type.sys-types, support.other.namespace</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#DAA520</string>  <!-- DR gold -->
      </dict>
    </dict>

    <!-- Type annotations / generic parameters (Python hints, TS generics) -->
    <dict>
      <key>name</key>    <string>Type — Annotation / Generic Parameter</string>
      <key>scope</key>   <string>meta.type.annotation, meta.type.parameters,
        meta.generic, meta.type-alias,
        support.type.python, support.type.swift,
        entity.name.type.go, entity.name.type.rust</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#DAA520</string>  <!-- DR gold italic -->
        <key>fontStyle</key>   <string>italic</string>
      </dict>
    </dict>

    <!-- Namespace / module names (used in imports, qualified references) -->
    <dict>
      <key>name</key>    <string>Type — Namespace / Module</string>
      <key>scope</key>   <string>entity.name.namespace, entity.name.module,
        entity.name.package, meta.namespace,
        support.module, support.other.module</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#DAA520</string>  <!-- DR gold -->
      </dict>
    </dict>

    <!-- Enum variants / cases (used as values, not definitions) -->
    <dict>
      <key>name</key>    <string>Type — Enum Variant / Case</string>
      <key>scope</key>   <string>entity.name.enum-member, variable.other.enummember,
        support.constant.enum, entity.name.case</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#DAA520</string>  <!-- DR gold — same family as types -->
      </dict>
    </dict>


    <!-- ════════════════════════════════════════════════════════════════════
         §9  VARIABLES
         ════════════════════════════════════════════════════════════════════
         Variables are the most common token in any file — they MUST stay
         invisible (blend with foreground). Crema (#FFF7EE) IS the default
         text color. Parameters get italic to signal "input to this scope".
         Properties are slightly receded (bone) since they're object-owned.
         ════════════════════════════════════════════════════════════════════ -->

    <!-- General variables (local vars, identifiers) — crema = default text -->
    <dict>
      <key>name</key>    <string>Variable — General</string>
      <key>scope</key>   <string>variable, variable.other,
        variable.other.readwrite, variable.other.local,
        variable.other.block, variable.other.captured</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#FFF7EE</string>  <!-- DR crema -->
      </dict>
    </dict>

    <!-- Function / method parameters — italic distinguishes "input" from "local" -->
    <dict>
      <key>name</key>    <string>Variable — Parameter</string>
      <key>scope</key>   <string>variable.parameter,
        variable.parameter.function, variable.parameter.rest,
        variable.other.jsdoc</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#FFF7EE</string>  <!-- DR crema italic -->
        <key>fontStyle</key>   <string>italic</string>
      </dict>
    </dict>

    <!-- Language-special variables: self, this, super, cls, Self, base -->
    <dict>
      <key>name</key>    <string>Variable — Language (self/this/super)</string>
      <key>scope</key>   <string>variable.language,
        variable.language.this, variable.language.self,
        variable.language.super, variable.language.base,
        variable.language.special</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#AD7FA8</string>  <!-- DR mauve italic — language-special = keyword treatment -->
        <key>fontStyle</key>   <string>italic</string>
      </dict>
    </dict>

    <!-- Object property access (obj.property) — bone: present but receded -->
    <dict>
      <key>name</key>    <string>Variable — Object Property / Member</string>
      <key>scope</key>   <string>variable.other.property,
        variable.other.object.property, variable.other.member,
        variable.other.field, meta.property.object</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#EBE1D7</string>  <!-- DR bone -->
      </dict>
    </dict>

    <!-- Constant variables (JS const, Rust const, Go const) -->
    <dict>
      <key>name</key>    <string>Variable — Constant / Immutable Binding</string>
      <key>scope</key>   <string>variable.other.constant,
        variable.other.constant.object,
        support.constant.handlebars</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#D2691E</string>  <!-- DR amber-hot — immutable = constant family -->
      </dict>
    </dict>

    <!-- Destructured / pattern binding variables -->
    <dict>
      <key>name</key>    <string>Variable — Destructured / Pattern</string>
      <key>scope</key>   <string>variable.other.binding, variable.other.pattern</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#FFF7EE</string>  <!-- DR crema — still just a local var -->
        <key>fontStyle</key>   <string>italic</string>
      </dict>
    </dict>


    <!-- ════════════════════════════════════════════════════════════════════
         §10  DECORATORS & ANNOTATIONS
         ════════════════════════════════════════════════════════════════════
         Decorators (@) are meta-programming constructs — they modify code
         without being code themselves. Amber (#E69A4C) is the primary accent
         and draws the eye to these structural annotations.
         Covers: Python @decorator, JS/TS @decorator, Java @Annotation,
         C# [Attribute], Rust #[derive(...)], Go struct tags.
         ════════════════════════════════════════════════════════════════════ -->

    <dict>
      <key>name</key>    <string>Decorator / Annotation — @ Symbol</string>
      <key>scope</key>   <string>punctuation.definition.decorator,
        punctuation.definition.annotation,
        keyword.decorator, keyword.decorator.python</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#E69A4C</string>  <!-- DR amber -->
      </dict>
    </dict>

    <dict>
      <key>name</key>    <string>Decorator / Annotation — Name</string>
      <key>scope</key>   <string>entity.name.function.decorator,
        entity.name.type.annotation, meta.decorator,
        meta.annotation, support.other.attribute</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#E69A4C</string>  <!-- DR amber italic -->
        <key>fontStyle</key>   <string>italic</string>
      </dict>
    </dict>

    <!-- C# / Java attributes in brackets [SerializeField] [Required] -->
    <dict>
      <key>name</key>    <string>Decorator — Attribute Bracket</string>
      <key>scope</key>   <string>meta.attribute.csharp, meta.attribute.java,
        punctuation.definition.attribute.begin,
        punctuation.definition.attribute.end</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#E69A4C</string>  <!-- DR amber -->
      </dict>
    </dict>

    <!-- Rust attributes: #[derive(Debug)], #[cfg(test)], #![allow(dead_code)] -->
    <dict>
      <key>name</key>    <string>Decorator — Rust Attribute</string>
      <key>scope</key>   <string>meta.attribute.rust, keyword.attribute.rust,
        punctuation.definition.attribute.rust</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#E69A4C</string>  <!-- DR amber -->
        <key>fontStyle</key>   <string>italic</string>
      </dict>
    </dict>


