        <key>foreground</key>  <string>#D2691E</string>  <!-- DR amber-hot italic — special borrow annotation -->
        <key>fontStyle</key>   <string>italic</string>
      </dict>
    </dict>

    <!-- Rust: macros: println!, vec!, format!, panic!, assert! -->
    <dict>
      <key>name</key>    <string>Rust — Macro Invocation</string>
      <key>scope</key>   <string>support.other.macro.rust,
        entity.name.function.macro.rust, keyword.operator.macro.rust,
        variable.other.macro.rust, meta.macro.rust</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#E69A4C</string>  <!-- DR amber — macros = meta-programming like decorators -->
        <key>fontStyle</key>   <string>italic</string>
      </dict>
    </dict>

    <!-- Rust: unsafe keyword -->
    <dict>
      <key>name</key>    <string>Rust — unsafe Keyword</string>
      <key>scope</key>   <string>keyword.other.unsafe.rust,
        storage.modifier.unsafe.rust</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#C44C4C</string>  <!-- DR scarlet bold — unsafe is CRITICAL -->
        <key>fontStyle</key>   <string>bold</string>
      </dict>
    </dict>

    <!-- Rust: impl block -->
    <dict>
      <key>name</key>    <string>Rust — impl / trait / where</string>
      <key>scope</key>   <string>keyword.other.rust, storage.type.rust</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#AD7FA8</string>  <!-- DR mauve italic -->
        <key>fontStyle</key>   <string>italic</string>
      </dict>
    </dict>


    <!-- ════════════════════════════════════════════════════════════════════
         §16  HTML / XML / JSX
         ════════════════════════════════════════════════════════════════════
         HTML tags are structural markup — scarlet is the universal red-for-
         HTML-tags convention that nearly every major theme uses. Attributes
         are amber: they parametrize the tag (constructive). Angle brackets
         are crater-lt: structure without noise.
         ════════════════════════════════════════════════════════════════════ -->

    <!-- HTML / XML element tag names: <div>, <p>, <span>, <table>, <svg> -->
    <dict>
      <key>name</key>    <string>HTML / XML — Tag Name</string>
      <key>scope</key>   <string>entity.name.tag,
        entity.name.tag.html, entity.name.tag.xml,
        entity.name.tag.svg, entity.name.tag.other</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#C44C4C</string>  <!-- DR scarlet -->
      </dict>
    </dict>

    <!-- Attribute names: class="…" id="…" href="…" data-* aria-* -->
    <dict>
      <key>name</key>    <string>HTML / XML — Attribute Name</string>
      <key>scope</key>   <string>entity.other.attribute-name,
        entity.other.attribute-name.html,
        entity.other.attribute-name.xml,
        entity.other.attribute-name.id.html</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#E69A4C</string>  <!-- DR amber -->
      </dict>
    </dict>

    <!-- Attribute values: ="value" (non-string, e.g. unquoted) -->
    <dict>
      <key>name</key>    <string>HTML / XML — Attribute Value (unquoted)</string>
      <key>scope</key>   <string>string.unquoted.html, string.unquoted.attribute-value</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#8AAC6B</string>  <!-- DR sage — values are strings -->
      </dict>
    </dict>

    <!-- Tag angle brackets < > </ /> -->
    <dict>
      <key>name</key>    <string>HTML / XML — Tag Punctuation</string>
      <key>scope</key>   <string>punctuation.definition.tag,
        punctuation.definition.tag.begin,
        punctuation.definition.tag.end,
        punctuation.definition.tag.html,
        punctuation.definition.tag.xml</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#4D3B31</string>  <!-- DR crater-lt — structural but quiet -->
      </dict>
    </dict>

    <!-- DOCTYPE, XML prolog, XML namespace -->
    <dict>
      <key>name</key>    <string>HTML / XML — DOCTYPE / Prolog</string>
      <key>scope</key>   <string>meta.tag.sgml.doctype, entity.name.tag.doctype,
        meta.tag.preprocessor.xml, keyword.operator.less-than.xml</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#8B7355</string>  <!-- DR mocha italic — boilerplate -->
        <key>fontStyle</key>   <string>italic</string>
      </dict>
    </dict>

    <!-- HTML/XML: &nbsp; &amp; &lt; entity references -->
    <dict>
      <key>name</key>    <string>HTML / XML — Character Entity</string>
      <key>scope</key>   <string>constant.character.entity.html,
        constant.character.entity.xml</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#C44C4C</string>  <!-- DR scarlet — breaks normal text flow -->
      </dict>
    </dict>

    <!-- Embedded script and style blocks -->
    <dict>
      <key>name</key>    <string>HTML — Embedded Script / Style Tag</string>
      <key>scope</key>   <string>entity.name.tag.script.html,
        entity.name.tag.style.html</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#C44C4C</string>  <!-- DR scarlet — still a tag name -->
        <key>fontStyle</key>   <string>bold</string>
      </dict>
    </dict>


    <!-- ════════════════════════════════════════════════════════════════════
         §17  CSS / SCSS / LESS
         ════════════════════════════════════════════════════════════════════
         CSS selectors define structural targets (like types → gold).
         CSS properties DO things (like functions → slate).
         CSS values are data (crema/bone depending on context).
         ════════════════════════════════════════════════════════════════════ -->

    <!-- CSS selectors: .class, #id, element, :pseudo, ::pseudo-element -->
    <dict>
      <key>name</key>    <string>CSS — Selector (element / tag)</string>
      <key>scope</key>   <string>entity.name.tag.css, entity.name.tag.scss,
        entity.name.tag.wildcard.css</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#DAA520</string>  <!-- DR gold -->
      </dict>
    </dict>

    <dict>
      <key>name</key>    <string>CSS — Selector (class / ID)</string>
      <key>scope</key>   <string>entity.other.attribute-name.class.css,
        entity.other.attribute-name.class.scss,
        entity.other.attribute-name.id.css,
        entity.other.attribute-name.id.scss</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#DAA520</string>  <!-- DR gold -->
      </dict>
    </dict>

    <dict>
      <key>name</key>    <string>CSS — Pseudo-class / Pseudo-element</string>
      <key>scope</key>   <string>entity.other.attribute-name.pseudo-class.css,
        entity.other.attribute-name.pseudo-element.css,
        entity.other.pseudo-class.css,
        entity.other.pseudo-element.css</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#DAA520</string>  <!-- DR gold italic — derived selector -->
        <key>fontStyle</key>   <string>italic</string>
      </dict>
    </dict>

    <!-- CSS property names: color, margin, display, flex-direction, … -->
    <dict>
      <key>name</key>    <string>CSS — Property Name</string>
      <key>scope</key>   <string>support.type.property-name.css,
        support.type.property-name.scss,
        support.type.property-name.less,
        meta.property-name.css</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#6E8FAD</string>  <!-- DR slate — properties DO things -->
      </dict>
    </dict>

    <!-- CSS custom properties / variables: (-\-color-primary), var(-\-font-size) -->
    <dict>
      <key>name</key>    <string>CSS — Custom Property (variable)</string>
      <key>scope</key>   <string>variable.css, variable.argument.css,
        support.type.custom-property.css,
        variable.other.custom-property.css,
        variable.scss, variable.less</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#E69A4C</string>  <!-- DR amber — CSS vars are accent-level constructs -->
      </dict>
    </dict>

    <!-- CSS property values: red, block, flex, none, inherit, … -->
    <dict>
      <key>name</key>    <string>CSS — Property Value (keyword)</string>
      <key>scope</key>   <string>support.constant.property-value.css,
        support.constant.property-value.scss,
        meta.property-value.css keyword,
        meta.property-value.scss keyword</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#EBE1D7</string>  <!-- DR bone — values are data, slightly receded -->
      </dict>
    </dict>

    <!-- CSS at-rules: @media, @keyframes, @import, @mixin, @include -->
    <dict>
      <key>name</key>    <string>CSS — At-Rule Keyword</string>
      <key>scope</key>   <string>keyword.control.at-rule.css,
        keyword.control.at-rule.scss,
        keyword.control.at-rule.less,
        punctuation.definition.keyword.css</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#AD7FA8</string>  <!-- DR mauve — at-rules = keyword family -->
        <key>fontStyle</key>   <string>italic</string>
      </dict>
    </dict>

    <!-- CSS units: px, em, rem, vh, vw, %, ms, deg -->
    <dict>
      <key>name</key>    <string>CSS — Unit</string>
      <key>scope</key>   <string>keyword.other.unit.css,
        keyword.other.unit.scss, keyword.other.unit.less</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#D2691E</string>  <!-- DR amber-hot — unit modifies the number -->
      </dict>
    </dict>

    <!-- CSS color values: #fff, #120C06, rgb(), hsl() -->
    <dict>
      <key>name</key>    <string>CSS — Color Value</string>
      <key>scope</key>   <string>constant.other.color.rgb-value.css,
        constant.other.color.rgb-value.hex.css,
        support.constant.color.w3c-standard-color-name.css</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#D2691E</string>  <!-- DR amber-hot — color = numeric literal family -->
      </dict>
    </dict>

    <!-- SCSS @mixin name, @function name, @include argument -->
    <dict>
      <key>name</key>    <string>SCSS — Mixin / Function Name</string>
      <key>scope</key>   <string>entity.name.function.scss, entity.name.mixin.scss,
        meta.function.scss entity.name</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#6E8FAD</string>  <!-- DR slate — SCSS functions = functions -->
      </dict>
    </dict>


    <!-- ════════════════════════════════════════════════════════════════════
         §18  JSON
         ════════════════════════════════════════════════════════════════════
         JSON keys are structural identifiers — slate for scannability.
         JSON values: strings=sage, numbers=amber-hot, booleans=amber-hot italic,
         null=amber-hot italic (consistent with language constants).
         ════════════════════════════════════════════════════════════════════ -->

    <!-- JSON object keys: "name", "version", "dependencies" -->
    <dict>
      <key>name</key>    <string>JSON — Key</string>
      <key>scope</key>   <string>support.type.property-name.json,
        string.quoted.double.json meta.structure.dictionary.key.json string.quoted.double.json,
        meta.mapping.key.json string.quoted.double.json</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#6E8FAD</string>  <!-- DR slate -->
      </dict>
    </dict>

    <!-- JSON string values: "hello", "https://…" -->
    <dict>
      <key>name</key>    <string>JSON — String Value</string>
      <key>scope</key>   <string>meta.structure.dictionary.value.json string.quoted.double.json,
        meta.mapping.value.json string.quoted.double.json,
        string.quoted.double.json</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#8AAC6B</string>  <!-- DR sage — strings = sage universally -->
      </dict>
    </dict>

    <!-- JSON boolean and null constants -->
    <dict>
      <key>name</key>    <string>JSON — Boolean / Null</string>
      <key>scope</key>   <string>constant.language.json</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#D2691E</string>  <!-- DR amber-hot italic — same as language constants -->
        <key>fontStyle</key>   <string>italic</string>
      </dict>
    </dict>

    <!-- JSON structure punctuation: { } [ ] : , -->
    <dict>
      <key>name</key>    <string>JSON — Structural Punctuation</string>
      <key>scope</key>   <string>punctuation.definition.dictionary.begin.json,
        punctuation.definition.dictionary.end.json,
        punctuation.definition.array.begin.json,
        punctuation.definition.array.end.json,
        punctuation.separator.dictionary.key-value.json,
        punctuation.separator.array.json</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#8B7355</string>  <!-- DR mocha — structure, quietly -->
      </dict>
    </dict>


    <!-- ════════════════════════════════════════════════════════════════════
         §19  YAML
         ════════════════════════════════════════════════════════════════════ -->

    <!-- YAML keys: name:, version:, dependencies: -->
    <dict>
      <key>name</key>    <string>YAML — Key</string>
      <key>scope</key>   <string>entity.name.tag.yaml,
        string.unquoted.plain.out.yaml,
        meta.mapping.key.yaml string</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#6E8FAD</string>  <!-- DR slate — structural keys -->
      </dict>
    </dict>

    <!-- YAML values: hello, 42, true, null -->
    <dict>
      <key>name</key>    <string>YAML — Value (string/unquoted)</string>
      <key>scope</key>   <string>string.unquoted.plain.in.yaml,
        string.quoted.single.yaml, string.quoted.double.yaml</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#8AAC6B</string>  <!-- DR sage -->
      </dict>
    </dict>

    <!-- YAML anchors & aliases: &anchor, *ref -->
    <dict>
      <key>name</key>    <string>YAML — Anchor / Alias</string>
      <key>scope</key>   <string>entity.name.type.anchor.yaml,
        variable.other.alias.yaml,
        punctuation.definition.anchor.yaml,
        punctuation.definition.alias.yaml</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#E69A4C</string>  <!-- DR amber — references = meta-programming -->
        <key>fontStyle</key>   <string>italic</string>
      </dict>
    </dict>

    <!-- YAML directives: (triple dash) ... %YAML -->
    <dict>
      <key>name</key>    <string>YAML — Directive / Document Marker</string>
      <key>scope</key>   <string>meta.document.yaml, punctuation.definition.document.yaml,
        keyword.other.directive.yaml</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#8B7355</string>  <!-- DR mocha — structural boilerplate -->
      </dict>
    </dict>

    <!-- YAML block scalars: | > -->
    <dict>
      <key>name</key>    <string>YAML — Block Scalar Indicator</string>
      <key>scope</key>   <string>keyword.control.flow.block-scalar.literal.yaml,
        keyword.control.flow.block-scalar.folded.yaml</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#4CC4B4</string>  <!-- DR teal — multi-line string delimiter -->
      </dict>
    </dict>


    <!-- ════════════════════════════════════════════════════════════════════
         §20  MARKDOWN
         ════════════════════════════════════════════════════════════════════
         Markdown is a writing format as much as a code format. The color
         scheme treats it as structured content: headings are landmarks
         (amber bold), bold/italic are emphasis (gold), code is data (sage),
         links are navigable (teal underline), blockquotes are quotes (mocha).
         ════════════════════════════════════════════════════════════════════ -->

    <!-- ATX and Setext headings: # H1 ## H2 ### H3 === (setext underline) -->
    <dict>
      <key>name</key>    <string>Markdown — Heading</string>
      <key>scope</key>   <string>markup.heading,
        markup.heading.1, markup.heading.2,
        markup.heading.3, markup.heading.4,
        markup.heading.5, markup.heading.6,
        entity.name.section.markdown</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#E69A4C</string>  <!-- DR amber bold — landmarks -->
        <key>fontStyle</key>   <string>bold</string>
      </dict>
    </dict>

    <!-- Heading # punctuation -->
    <dict>
      <key>name</key>    <string>Markdown — Heading Punctuation</string>
      <key>scope</key>   <string>punctuation.definition.heading.markdown,
        punctuation.definition.heading.setext</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#E69A4C</string>  <!-- DR amber — unified with heading -->
      </dict>
    </dict>

    <!-- **bold** and __bold__ -->
    <dict>
      <key>name</key>    <string>Markdown — Bold</string>
      <key>scope</key>   <string>markup.bold, markup.bold string</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#DAA520</string>  <!-- DR gold bold -->
        <key>fontStyle</key>   <string>bold</string>
      </dict>
    </dict>

    <!-- *italic* and _italic_ -->
    <dict>
      <key>name</key>    <string>Markdown — Italic</string>
      <key>scope</key>   <string>markup.italic, markup.italic string</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#DAA520</string>  <!-- DR gold italic -->
        <key>fontStyle</key>   <string>italic</string>
      </dict>
    </dict>

    <!-- ***bold italic*** -->
    <dict>
      <key>name</key>    <string>Markdown — Bold Italic</string>
      <key>scope</key>   <string>markup.bold markup.italic, markup.italic markup.bold</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#DAA520</string>  <!-- DR gold bold italic -->
        <key>fontStyle</key>   <string>bold italic</string>
      </dict>
    </dict>

    <!-- `inline code` -->
    <dict>
      <key>name</key>    <string>Markdown — Inline Code</string>
      <key>scope</key>   <string>markup.inline.raw,
        markup.raw.inline, markup.inline.raw.string.markdown</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#8AAC6B</string>  <!-- DR sage — code = strings = data -->
      </dict>
    </dict>

    <!-- ```code blocks``` -->
    <dict>
      <key>name</key>    <string>Markdown — Code Block / Fenced</string>
      <key>scope</key>   <string>markup.raw.block, markup.fenced_code.block.markdown,
        markup.code.fenced, markup.raw.code-fence</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#8AAC6B</string>  <!-- DR sage -->
      </dict>
    </dict>

    <!-- Fenced code block language identifier: ```python, ```typescript -->
    <dict>
      <key>name</key>    <string>Markdown — Fenced Code Language</string>
      <key>scope</key>   <string>constant.other.language-name.markdown,
        variable.language.fenced.markdown, fenced_code.block.language</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#E69A4C</string>  <!-- DR amber italic — language tag is a label -->
        <key>fontStyle</key>   <string>italic</string>
      </dict>
    </dict>

    <!-- [link text](url) and ![alt](url) — URL portion -->
    <dict>
      <key>name</key>    <string>Markdown — Link / URL</string>
      <key>scope</key>   <string>markup.underline.link,
        markup.underline.link.image, string.other.link.description.markdown,
        string.other.link.title.markdown</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#4CC4B4</string>  <!-- DR teal underline — navigable = kinetic -->
        <key>fontStyle</key>   <string>underline</string>
      </dict>
    </dict>

    <!-- [link text] — the visible text of a link -->
    <dict>
      <key>name</key>    <string>Markdown — Link Label Text</string>
      <key>scope</key>   <string>string.other.link.description.title.markdown,
        meta.image.inline.markdown string, meta.link.inline.markdown string</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#EBE1D7</string>  <!-- DR bone — link text stays readable -->
      </dict>
    </dict>

    <!-- - and * list bullets, 1. numbered lists -->
    <dict>
      <key>name</key>    <string>Markdown — List Bullet</string>
      <key>scope</key>   <string>markup.list, punctuation.definition.list.begin.markdown,
        markup.list.unnumbered, markup.list.numbered</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#DAA520</string>  <!-- DR gold — list structure is stable -->
      </dict>
    </dict>

    <!-- > blockquotes -->
    <dict>
      <key>name</key>    <string>Markdown — Blockquote</string>
      <key>scope</key>   <string>markup.quote, punctuation.definition.blockquote.markdown</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#8B7355</string>  <!-- DR mocha italic — cited text recedes -->
        <key>fontStyle</key>   <string>italic</string>
      </dict>
    </dict>

    <!-- Horizontal rule (triple dash/asterisk) -->
    <dict>
      <key>name</key>    <string>Markdown — Horizontal Rule</string>
      <key>scope</key>   <string>meta.separator.markdown, punctuation.definition.thematic-break</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#4D3B31</string>  <!-- DR crater-lt — structural divider -->
      </dict>
    </dict>

    <!-- []: reference link definitions -->
    <dict>
      <key>name</key>    <string>Markdown — Reference / Label</string>
      <key>scope</key>   <string>constant.other.reference.link.markdown,
        meta.link.reference.markdown</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#E69A4C</string>  <!-- DR amber — references like anchors/decorators -->
      </dict>
    </dict>


    <!-- ════════════════════════════════════════════════════════════════════
         §21  SHELL / BASH / ZSH
         ════════════════════════════════════════════════════════════════════ -->

    <!-- Shell built-in commands: cd, echo, export, source, eval -->
    <dict>
      <key>name</key>    <string>Shell — Built-in Command</string>
      <key>scope</key>   <string>support.function.builtin.shell,
        support.function.builtin.bash, keyword.other.shell</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#6E8FAD</string>  <!-- DR slate italic — built-in functions -->
        <key>fontStyle</key>   <string>italic</string>
      </dict>
    </dict>

    <!-- Shell variables: $HOME, $USER, ${VAR}, $0 $1 $@ $# -->
    <dict>
      <key>name</key>    <string>Shell — Variable / Parameter</string>
      <key>scope</key>   <string>variable.other.normal.shell,
        variable.other.special.shell, variable.other.positional.shell,
        variable.other.bracket.shell, variable.other.readwrite.shell</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#E69A4C</string>  <!-- DR amber — shell vars are accent-level -->
      </dict>
    </dict>

    <!-- Shell variable punctuation: ${ } -->
    <dict>
      <key>name</key>    <string>Shell — Variable Punctuation</string>
      <key>scope</key>   <string>punctuation.definition.variable.shell</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#E69A4C</string>  <!-- DR amber -->
      </dict>
    </dict>

    <!-- Here-doc: <<EOF ... EOF -->
    <dict>
      <key>name</key>    <string>Shell — Heredoc Delimiter</string>
      <key>scope</key>   <string>keyword.operator.heredoc.shell,
        punctuation.definition.string.heredoc.shell</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#4CC4B4</string>  <!-- DR teal — heredoc delimiter marks evaluated block -->
      </dict>
    </dict>

    <!-- Command substitution: $(cmd) `cmd` -->
    <dict>
      <key>name</key>    <string>Shell — Command Substitution</string>
      <key>scope</key>   <string>meta.command-substitution.shell,
        punctuation.definition.command-substitution.shell</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#4CC4B4</string>  <!-- DR teal — evaluated = live -->
      </dict>
    </dict>

    <!-- Flags and options: -v, (-\-verbose), (-\-port) -->
    <dict>
      <key>name</key>    <string>Shell — Flag / Option</string>
      <key>scope</key>   <string>string.unquoted.argument.shell,
        variable.language.special.dash.shell</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#EBE1D7</string>  <!-- DR bone — arguments slightly receded -->
      </dict>
    </dict>


    <!-- ════════════════════════════════════════════════════════════════════
         §22  SQL
         ════════════════════════════════════════════════════════════════════ -->

    <!-- SQL keywords: SELECT FROM WHERE GROUP BY ORDER HAVING JOIN ON
         INSERT UPDATE DELETE CREATE DROP ALTER INDEX UNIQUE -->
    <dict>
      <key>name</key>    <string>SQL — Keyword</string>
      <key>scope</key>   <string>keyword.other.sql, keyword.dml.sql,
        keyword.ddl.sql, keyword.other.create.sql,
        keyword.other.drop.sql, keyword.other.alter.sql</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#AD7FA8</string>  <!-- DR mauve bold — SQL keywords = keyword family -->
        <key>fontStyle</key>   <string>bold</string>
      </dict>
    </dict>

    <!-- SQL functions: COUNT(), SUM(), AVG(), COALESCE(), NOW() -->
    <dict>
      <key>name</key>    <string>SQL — Function</string>
      <key>scope</key>   <string>support.function.aggregate.sql,
        support.function.scalar.sql, support.function.window.sql</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#6E8FAD</string>  <!-- DR slate — functions = slate -->
      </dict>
    </dict>

    <!-- SQL table / column names (identifiers) -->
    <dict>
      <key>name</key>    <string>SQL — Identifier</string>
      <key>scope</key>   <string>entity.name.table.sql, entity.name.column.sql</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#DAA520</string>  <!-- DR gold — schema objects = types -->
      </dict>
    </dict>

    <!-- SQL operators: =, !=, <, >, LIKE, IN, BETWEEN, IS NULL, AND, OR, NOT -->
    <dict>
      <key>name</key>    <string>SQL — Operator</string>
      <key>scope</key>   <string>keyword.operator.comparison.sql,
        keyword.operator.logical.sql</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#4CC4B4</string>  <!-- DR teal — operators = teal -->
      </dict>
    </dict>


    <!-- ════════════════════════════════════════════════════════════════════
         §23  RUBY
         ════════════════════════════════════════════════════════════════════ -->

    <!-- Ruby symbols: :name, :key, :"string-sym" -->
    <dict>
      <key>name</key>    <string>Ruby — Symbol</string>
      <key>scope</key>   <string>constant.other.symbol.ruby,
        constant.other.symbol.hashkey.ruby,
        punctuation.definition.symbol.ruby</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#D2691E</string>  <!-- DR amber-hot — symbols are constants -->
      </dict>
    </dict>

    <!-- Ruby string interpolation: #{expr} -->
    <dict>
      <key>name</key>    <string>Ruby — String Interpolation</string>
      <key>scope</key>   <string>punctuation.section.embedded.ruby,
        source.ruby.embedded.source</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#4CC4B4</string>  <!-- DR teal — embedded expression = live -->
      </dict>
    </dict>

    <!-- Ruby blocks: do |x| ... end, { |x| ... } -->
    <dict>
      <key>name</key>    <string>Ruby — Block Parameter Pipes</string>
      <key>scope</key>   <string>punctuation.separator.variable.ruby,
        punctuation.definition.parameters.ruby</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#8B7355</string>  <!-- DR mocha — structural framing -->
      </dict>
    </dict>


    <!-- ════════════════════════════════════════════════════════════════════
         §24  PHP
         ════════════════════════════════════════════════════════════════════ -->

    <!-- PHP variables: $name, $this, $POST, $GLOBALS -->
    <dict>
      <key>name</key>    <string>PHP — Variable</string>
      <key>scope</key>   <string>variable.other.php, variable.parameter.php</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#FFF7EE</string>  <!-- DR crema — PHP vars are just vars -->
      </dict>
    </dict>

    <!-- PHP $ sigil -->
    <dict>
      <key>name</key>    <string>PHP — Variable Dollar Sign</string>
      <key>scope</key>   <string>punctuation.definition.variable.php</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#E69A4C</string>  <!-- DR amber — sigil is accent -->
      </dict>
    </dict>

    <!-- PHP: echo, print, list, empty, isset, unset — language constructs -->
    <dict>
      <key>name</key>    <string>PHP — Language Construct</string>
      <key>scope</key>   <string>support.function.construct.php,
        keyword.other.new.php</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#AD7FA8</string>  <!-- DR mauve — language-level constructs -->
        <key>fontStyle</key>   <string>italic</string>
      </dict>
    </dict>

    <!-- PHP open/close tags: <?php ?> -->
    <dict>
      <key>name</key>    <string>PHP — Open / Close Tags</string>
      <key>scope</key>   <string>punctuation.section.embedded.begin.php,
        punctuation.section.embedded.end.php,
        meta.embedded.line.php punctuation</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#C44C4C</string>  <!-- DR scarlet — tag = markup family -->
        <key>fontStyle</key>   <string>bold</string>
      </dict>
    </dict>


    <!-- ════════════════════════════════════════════════════════════════════
         §25  JAVA
         ════════════════════════════════════════════════════════════════════ -->

    <!-- Java annotations: @Override, @NonNull, @SuppressWarnings -->
    <dict>
      <key>name</key>    <string>Java — Annotation</string>
      <key>scope</key>   <string>storage.type.annotation.java,
        punctuation.definition.annotation.java,
        entity.name.type.annotation.java</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#E69A4C</string>  <!-- DR amber — annotations = decorators -->
        <key>fontStyle</key>   <string>italic</string>
      </dict>
    </dict>

    <!-- Java import paths -->
    <dict>
      <key>name</key>    <string>Java — Import Path</string>
      <key>scope</key>   <string>storage.modifier.import.java,
        storage.modifier.package.java</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#EBE1D7</string>  <!-- DR bone — import paths are context -->
      </dict>
    </dict>


    <!-- ════════════════════════════════════════════════════════════════════
         §26  C / C++ / OBJECTIVE-C
         ════════════════════════════════════════════════════════════════════ -->

    <!-- Preprocessor directives: #include, #define, #ifdef, #pragma -->
    <dict>
      <key>name</key>    <string>C/C++ — Preprocessor Directive</string>
      <key>scope</key>   <string>keyword.control.import.c, keyword.control.import.c++,
        keyword.control.directive, meta.preprocessor keyword,
        punctuation.definition.directive</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#E69A4C</string>  <!-- DR amber — preprocessor = meta-programming -->
        <key>fontStyle</key>   <string>italic</string>
      </dict>
    </dict>

    <!-- Preprocessor macro names: #define MACRO_NAME -->
    <dict>
      <key>name</key>    <string>C/C++ — Macro / Defined Constant</string>
      <key>scope</key>   <string>entity.name.function.preprocessor.c,
        entity.name.function.preprocessor.c++,
        entity.name.constant.preprocessor.c</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#D2691E</string>  <!-- DR amber-hot — macros are constant-like -->
      </dict>
    </dict>

    <!-- ObjC message send: [object message] brackets -->
    <dict>
      <key>name</key>    <string>Objective-C — Message Send</string>
      <key>scope</key>   <string>meta.brackets.objc, keyword.other.property.objc</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#8B7355</string>  <!-- DR mocha — message brackets are structure -->
      </dict>
    </dict>

    <!-- ObjC / C++ nullptr, NULL, YES, NO, true, false — covered by constant.language -->

    <!-- C/C++ primitive types: int, char, float, double, void, bool, long, short -->
    <dict>
      <key>name</key>    <string>C/C++ — Primitive Type</string>
      <key>scope</key>   <string>storage.type.c, storage.type.c++,
        storage.type.primitive.c, storage.type.primitive.c++</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#DAA520</string>  <!-- DR gold — primitive types = type family -->
        <key>fontStyle</key>   <string>italic</string>
      </dict>
    </dict>

    <!-- C/C++ pointer operator: * & (as type qualifiers) -->
    <dict>
      <key>name</key>    <string>C/C++ — Pointer / Reference Qualifier</string>
      <key>scope</key>   <string>storage.modifier.pointer.c, storage.modifier.reference.c++,
        keyword.operator.pointer.c, keyword.operator.address.c++</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#4CC4B4</string>  <!-- DR teal — pointer ops = operator family -->
      </dict>
    </dict>


    <!-- ════════════════════════════════════════════════════════════════════
         §27  PUNCTUATION & STRUCTURAL CHARACTERS
         ════════════════════════════════════════════════════════════════════
         Punctuation should recede. Separators and terminators use crater-lt
         so they're visible but never compete with code tokens.
         Brackets/braces/parens use mocha — they frame code without becoming
         part of the semantic color vocabulary.
         ════════════════════════════════════════════════════════════════════ -->

    <!-- Separators: , ; — -->
    <dict>
      <key>name</key>    <string>Punctuation — Separator / Terminator</string>
      <key>scope</key>   <string>punctuation.separator, punctuation.terminator,
        punctuation.separator.comma, punctuation.separator.key-value,
        punctuation.separator.sequence</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#4D3B31</string>  <!-- DR crater-lt — quiet structural separator -->
      </dict>
    </dict>

    <!-- Braces, brackets, parentheses: { } [ ] ( ) -->
    <dict>
      <key>name</key>    <string>Punctuation — Braces / Brackets / Parens</string>
      <key>scope</key>   <string>punctuation.definition.block,
        punctuation.definition.parameters.begin,
        punctuation.definition.parameters.end,
        punctuation.definition.array.begin,
        punctuation.definition.array.end,
        punctuation.section.block.begin,
        punctuation.section.block.end,
        punctuation.section.parens.begin,
        punctuation.section.parens.end,
        meta.brace.round, meta.brace.square, meta.brace.curly</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#8B7355</string>  <!-- DR mocha — structural framing -->
      </dict>
    </dict>

    <!-- String definition punctuation (quote marks) — handled per-string above -->

    <!-- Comment definition punctuation: //, /*, #, (double dash) -->
    <dict>
      <key>name</key>    <string>Punctuation — Comment Definition</string>
      <key>scope</key>   <string>punctuation.definition.comment</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#8B7355</string>  <!-- DR mocha — same as comment body -->
      </dict>
    </dict>


    <!-- ════════════════════════════════════════════════════════════════════
         §28  INVALID & DEPRECATED
         ════════════════════════════════════════════════════════════════════
         Scarlet (#C44C4C) is the ONLY correct use for error-state code.
         The canonical spec reserves scarlet for actual errors — which is
         why keywords were deliberately moved to mauve.
         Deprecated tokens get crater-lt + strikethrough: they are "dying".
         ════════════════════════════════════════════════════════════════════ -->

    <dict>
      <key>name</key>    <string>Invalid — Error / Illegal</string>
      <key>scope</key>   <string>invalid, invalid.illegal</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#C44C4C</string>  <!-- DR scarlet -->
        <key>background</key>  <string>#48060720</string> <!-- DR rose bg @ ~12% — tinted error bg -->
        <key>fontStyle</key>   <string>underline</string>
      </dict>
    </dict>

    <dict>
      <key>name</key>    <string>Invalid — Deprecated</string>
      <key>scope</key>   <string>invalid.deprecated</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#4D3B31</string>  <!-- DR crater-lt — visually dying -->
        <key>fontStyle</key>   <string>strikethrough</string>
      </dict>
    </dict>


    <!-- ════════════════════════════════════════════════════════════════════
         §29  DIFF / VERSION CONTROL
         ════════════════════════════════════════════════════════════════════
         Green = added (sage), Red = removed (scarlet), Amber = modified/changed.
         This is the universal semantic of diff colors.
         ════════════════════════════════════════════════════════════════════ -->

    <dict>
      <key>name</key>    <string>Diff — Inserted / Added</string>
      <key>scope</key>   <string>markup.inserted,
        markup.inserted.diff, markup.inserted.git_gutter</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#8AAC6B</string>  <!-- DR sage — green = added -->
      </dict>
    </dict>

    <dict>
      <key>name</key>    <string>Diff — Deleted / Removed</string>
      <key>scope</key>   <string>markup.deleted,
        markup.deleted.diff, markup.deleted.git_gutter</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#C44C4C</string>  <!-- DR scarlet — red = removed -->
      </dict>
    </dict>

    <dict>
      <key>name</key>    <string>Diff — Modified / Changed</string>
      <key>scope</key>   <string>markup.changed,
        markup.changed.diff, markup.changed.git_gutter</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#E69A4C</string>  <!-- DR amber — amber = modified -->
      </dict>
    </dict>

    <!-- Diff file headers: old/file.py new/file.py and @@ hunk markers -->
    <dict>
      <key>name</key>    <string>Diff — Header / Hunk</string>
      <key>scope</key>   <string>meta.diff.header, meta.diff.range,
        punctuation.definition.range.diff</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#8B7355</string>  <!-- DR mocha italic — metadata, recedes -->
        <key>fontStyle</key>   <string>italic</string>
      </dict>
    </dict>


    <!-- ════════════════════════════════════════════════════════════════════
         §30  TOML
         ════════════════════════════════════════════════════════════════════ -->

    <!-- TOML section headers: [section] [[array-of-tables]] -->
    <dict>
      <key>name</key>    <string>TOML — Table Header</string>
      <key>scope</key>   <string>entity.name.section.toml,
        punctuation.definition.table.toml,
        support.type.property-name.table.toml</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#DAA520</string>  <!-- DR gold — sections define structure like types -->
        <key>fontStyle</key>   <string>bold</string>
      </dict>
    </dict>

    <!-- TOML keys: key = value -->
    <dict>
      <key>name</key>    <string>TOML — Key</string>
      <key>scope</key>   <string>support.type.property-name.toml,
        keyword.key.toml</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#6E8FAD</string>  <!-- DR slate — structural keys -->
      </dict>
    </dict>


    <!-- ════════════════════════════════════════════════════════════════════
         §31  INI / PROPERTIES FILES
         ════════════════════════════════════════════════════════════════════ -->

    <dict>
      <key>name</key>    <string>INI / Properties — Section</string>
      <key>scope</key>   <string>entity.name.section.group-title.ini,
        entity.name.section.ini</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#DAA520</string>  <!-- DR gold bold -->
        <key>fontStyle</key>   <string>bold</string>
      </dict>
    </dict>

    <dict>
      <key>name</key>    <string>INI / Properties — Key</string>
      <key>scope</key>   <string>keyword.other.definition.ini,
        support.type.property-name.ini</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#6E8FAD</string>  <!-- DR slate -->
      </dict>
    </dict>


    <!-- ════════════════════════════════════════════════════════════════════
         §32  TEMPLATE LANGUAGES (Jinja2, Django, Handlebars, Twig)
         ════════════════════════════════════════════════════════════════════ -->

    <!-- Template tags: {% block %} {% extends %} {% for %} {% if %} -->
    <dict>
      <key>name</key>    <string>Template — Tag</string>
      <key>scope</key>   <string>entity.name.tag.template,
        keyword.control.template, keyword.control.jinja,
        meta.tag.template entity.name.tag</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#AD7FA8</string>  <!-- DR mauve — template control = keyword family -->
      </dict>
    </dict>

    <!-- Template expression delimiters: {{ }} {# #} {% %} -->
    <dict>
      <key>name</key>    <string>Template — Expression Delimiter</string>
      <key>scope</key>   <string>punctuation.definition.template-expression.jinja,
        punctuation.definition.block.jinja,
        punctuation.definition.comment.jinja,
        entity.other.jinja2.delimiter.statement,
        entity.other.jinja2.delimiter.variable</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#4CC4B4</string>  <!-- DR teal — evaluated expressions -->
      </dict>
    </dict>

    <!-- Handlebars expressions: {{name}} {{#each}} {{/each}} -->
    <dict>
      <key>name</key>    <string>Template — Handlebars Expression</string>
      <key>scope</key>   <string>expression.handlebars, meta.function.handlebars,
        support.constant.handlebars</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#4CC4B4</string>  <!-- DR teal — evaluated = live -->
      </dict>
    </dict>


    <!-- ════════════════════════════════════════════════════════════════════
         §33  ADDITIONAL SCOPES (catchall completeness)
         ════════════════════════════════════════════════════════════════════ -->

    <!-- Generic entity names (fallback for entity.name.* not covered above) -->
    <dict>
      <key>name</key>    <string>Entity — Generic Name</string>
      <key>scope</key>   <string>entity.name</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#DAA520</string>  <!-- DR gold — named entities default to type family -->
      </dict>
    </dict>

    <!-- Support catch-all (library/framework provided identifiers) -->
    <dict>
      <key>name</key>    <string>Support — Other</string>
      <key>scope</key>   <string>support.other, support.variable</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#EBE1D7</string>  <!-- DR bone — library vars slightly receded -->
      </dict>
    </dict>

    <!-- Generic markup (catch-all for markup.* not otherwise specified) -->
    <dict>
      <key>name</key>    <string>Markup — Other</string>
      <key>scope</key>   <string>markup.other</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#EBE1D7</string>  <!-- DR bone -->
      </dict>
    </dict>

    <!-- meta.output — terminal output blocks (e.g. in literate programming) -->
    <dict>
      <key>name</key>    <string>Meta — Output / Terminal</string>
      <key>scope</key>   <string>meta.output</string>
      <key>settings</key>
      <dict>
        <key>foreground</key>  <string>#8B7355</string>  <!-- DR mocha — output is context, not code -->
      </dict>
    </dict>

  </array>
</dict>
</plist>
